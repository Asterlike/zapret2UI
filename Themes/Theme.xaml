<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:mvvm="clr-namespace:ZapretUI.Mvvm"
                    xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf">

    <!-- ====================== Converters ====================== -->
    <mvvm:InverseBoolConverter x:Key="InverseBool"/>
    <mvvm:BoolToVisibilityConverter x:Key="BoolToVis"/>
    <mvvm:StateToBrushConverter x:Key="StateToBrush"/>
    <mvvm:StateToTextConverter x:Key="StateToText"/>
    <mvvm:DiagStatusToTextConverter x:Key="DiagText"/>
    <mvvm:DiagStatusToBrushConverter x:Key="DiagBrush"/>
    <mvvm:RefEqualsToVisibilityConverter x:Key="RefEqualsToVis"/>

    <!-- ====================== Palette (redesign · concept C) ====================== -->
    <Color x:Key="C.Bg">#FF090C11</Color>
    <Color x:Key="C.Surface">#FF11161F</Color>
    <Color x:Key="C.Card">#FF141B25</Color>
    <Color x:Key="C.SurfaceAlt">#FF1C2431</Color>
    <Color x:Key="C.Border">#1AFFFFFF</Color>
    <Color x:Key="C.Fg">#FFEDF1F8</Color>
    <Color x:Key="C.FgMuted">#FF92A0B3</Color>
    <Color x:Key="C.Muted2">#FF5B6675</Color>
    <Color x:Key="C.Accent">#FFA78BFA</Color>
    <Color x:Key="C.AccentHover">#FF6D4BD8</Color>
    <Color x:Key="C.AccentSoft">#24A78BFA</Color>

    <SolidColorBrush x:Key="BgBrush"        Color="{StaticResource C.Bg}"/>
    <SolidColorBrush x:Key="SurfaceBrush"   Color="{StaticResource C.Surface}"/>
    <SolidColorBrush x:Key="CardBrush"      Color="{StaticResource C.Card}"/>
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="{StaticResource C.SurfaceAlt}"/>
    <SolidColorBrush x:Key="BorderBrush2"   Color="{StaticResource C.Border}"/>
    <SolidColorBrush x:Key="FgBrush"        Color="{StaticResource C.Fg}"/>
    <SolidColorBrush x:Key="FgMutedBrush"   Color="{StaticResource C.FgMuted}"/>
    <SolidColorBrush x:Key="Muted2Brush"    Color="{StaticResource C.Muted2}"/>
    <SolidColorBrush x:Key="AccentBrush"    Color="{StaticResource C.Accent}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource C.AccentHover}"/>
    <SolidColorBrush x:Key="AccentSoftBrush" Color="{StaticResource C.AccentSoft}"/>
    <SolidColorBrush x:Key="SuccessBrush"   Color="#FF34D399"/>
    <SolidColorBrush x:Key="DangerBrush"    Color="#FFE2566A"/>
    <SolidColorBrush x:Key="WarnBrush"      Color="#FFF5A623"/>

    <!-- Bundled OFL fonts (see ZapretUI.csproj Resource glob). Folder pack-URI + family name. -->
    <FontFamily x:Key="UiFont">/Assets/Fonts/#Hanken Grotesk</FontFamily>
    <FontFamily x:Key="DisplayFont">/Assets/Fonts/#Space Grotesk</FontFamily>
    <FontFamily x:Key="MonoFont">/Assets/Fonts/#JetBrains Mono</FontFamily>

    <!-- ====================== Base typography ====================== -->
    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
    </Style>

    <!-- Color-emoji TextBlock (Emoji.Wpf) inherits the base TextBlock typography so it is a
         true drop-in. Use <emoji:TextBlock> wherever text may contain emoji. -->
    <Style TargetType="{x:Type emoji:TextBlock}" BasedOn="{StaticResource {x:Type TextBlock}}"/>

    <Style x:Key="H1" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource DisplayFont}"/>
        <Setter Property="FontSize" Value="22"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>
    <Style x:Key="H2" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource DisplayFont}"/>
        <Setter Property="FontSize" Value="16"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>
    <Style x:Key="Muted" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource FgMutedBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
        <Setter Property="FontSize" Value="12.5"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <!-- ====================== Card ====================== -->
    <Style x:Key="Card" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource CardBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush2}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="14"/>
        <Setter Property="Padding" Value="18"/>
    </Style>

    <!-- Modal dialog card: a Card that fades + scales in when it becomes visible.
         Each instance must set its own RenderTransform (a ScaleTransform) inline. -->
    <Style x:Key="ModalCard" TargetType="Border" BasedOn="{StaticResource Card}">
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        <Style.Triggers>
            <Trigger Property="IsVisible" Value="True">
                <Trigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             From="0" To="1" Duration="0:0:0.18"/>
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                             From="0.95" To="1" Duration="0:0:0.22">
                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                             From="0.95" To="1" Duration="0:0:0.22">
                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.EnterActions>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ====================== Scrollbars ====================== -->
    <!-- Thin, flat, dark thumb that brightens on hover/drag — matches the app chrome. -->
    <Style x:Key="ScrollThumb" TargetType="Thumb">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="IsTabStop" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border x:Name="t" CornerRadius="4" Margin="2" Background="#3AFFFFFF"/>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="t" Property="Background" Value="#5CFFFFFF"/>
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="t" Property="Background" Value="{StaticResource AccentBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Invisible page-track buttons (no arrow chrome). -->
    <Style x:Key="ScrollPageButton" TargetType="RepeatButton">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="IsTabStop" Value="False"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border Background="Transparent"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Width" Value="11"/>
        <Setter Property="MinWidth" Value="11"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Background="Transparent">
                        <Track x:Name="PART_Track" Orientation="{TemplateBinding Orientation}"
                               IsDirectionReversed="True">
                            <Track.Thumb>
                                <Thumb Style="{StaticResource ScrollThumb}"/>
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageDownCommand" Style="{StaticResource ScrollPageButton}"/>
                            </Track.IncreaseRepeatButton>
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageUpCommand" Style="{StaticResource ScrollPageButton}"/>
                            </Track.DecreaseRepeatButton>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Width" Value="Auto"/>
                <Setter Property="MinWidth" Value="0"/>
                <Setter Property="Height" Value="11"/>
                <Setter Property="MinHeight" Value="11"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ====================== Buttons ====================== -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
        <Setter Property="FontSize" Value="13.5"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="16,9"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Background="{TemplateBinding Background}"
                            CornerRadius="9" Padding="{TemplateBinding Padding}"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform><ScaleTransform x:Name="bs" ScaleX="1" ScaleY="1"/></Border.RenderTransform>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="bs" Storyboard.TargetProperty="ScaleX"
                                                         To="1.03" Duration="0:0:0.12"/>
                                        <DoubleAnimation Storyboard.TargetName="bs" Storyboard.TargetProperty="ScaleY"
                                                         To="1.03" Duration="0:0:0.12"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="bs" Storyboard.TargetProperty="ScaleX"
                                                         To="1" Duration="0:0:0.12"/>
                                        <DoubleAnimation Storyboard.TargetName="bs" Storyboard.TargetProperty="ScaleY"
                                                         To="1" Duration="0:0:0.12"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="b" Property="Opacity" Value="0.4"/>
                            <Setter Property="Cursor" Value="Arrow"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="GhostButton" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
        <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="13,8"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Background="{TemplateBinding Background}"
                            BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1"
                            CornerRadius="9" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="b" Property="Opacity" Value="0.4"/>
                            <Setter Property="Cursor" Value="Arrow"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Destructive (delete) button — red, darker on hover -->
    <Style x:Key="DangerButton" TargetType="Button">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
        <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="14,8"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Background="{TemplateBinding Background}"
                            CornerRadius="9" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="#FFD83A3A"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="b" Property="Opacity" Value="0.4"/>
                            <Setter Property="Cursor" Value="Arrow"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ====================== TextBox ====================== -->
    <Style TargetType="TextBox">
        <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
        <Setter Property="CaretBrush" Value="{StaticResource FgBrush}"/>
        <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush2}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontFamily" Value="{StaticResource UiFont}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="SelectionBrush" Value="{StaticResource AccentBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="b" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ====================== ListBox (generic) ====================== -->
    <Style TargetType="ListBox">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
    </Style>

    <Style x:Key="SelectableItem" TargetType="ListBoxItem">
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="Margin" Value="0,2"/>
        <Setter Property="Foreground" Value="{StaticResource FgBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="b" Background="Transparent" CornerRadius="8"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="b" Property="Background" Value="{StaticResource SurfaceAltBrush}"/>
                            <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            <Setter TargetName="b" Property="BorderThickness" Value="1"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <FontFamily x:Key="IconFont">Segoe Fluent Icons, Segoe MDL2 Assets</FontFamily>

    <!-- ====================== Brand logos ======================
         Real Discord / YouTube / Telegram marks so users recognise the targets at a glance.
         Vector paths from Simple Icons (CC0), 24x24 viewBox, default EvenOdd fill so the negative
         space (Discord eyes / YouTube triangle / Telegram plane) shows through. Render with a Path:
         <Path Data="{StaticResource Icon.Discord}" Fill="{StaticResource Brand.Discord}"
               Width="16" Height="16" Stretch="Uniform"/> -->
    <SolidColorBrush x:Key="Brand.Discord"  Color="#5865F2"/>
    <SolidColorBrush x:Key="Brand.YouTube"  Color="#FF0033"/>
    <SolidColorBrush x:Key="Brand.Telegram" Color="#2CA5E0"/>
