<Window x:Class="Zapret2UI.ConflictDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Возможный конфликт"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner" ShowInTaskbar="False"
        SizeToContent="WidthAndHeight">

    <Border Background="{StaticResource SurfaceBrush}" CornerRadius="14"
            BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1" MaxWidth="470">
        <StackPanel Margin="24" MouseLeftButtonDown="OnDrag">
            <TextBlock Text="Обнаружены возможные конфликты" Style="{StaticResource H2}"/>
            <TextBlock Style="{StaticResource Muted}" Margin="0,10,0,0" TextWrapping="Wrap"
                       Text="Эти программы обычно мешают обходу: другой обход блокировок занимает драйвер WinDivert, а VPN уводит трафик мимо движка. Перед запуском обхода их лучше закрыть."/>

            <ItemsControl x:Name="List" Margin="0,14,0,0">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource BgBrush}" BorderBrush="{StaticResource BorderBrush2}"
                                BorderThickness="1" CornerRadius="8" Padding="12,8" Margin="0,0,0,6">
                            <TextBlock Text="{Binding}" TextWrapping="Wrap" FontSize="12.5"/>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                <Button Content="Понятно" Style="{StaticResource PrimaryButton}"
                        Click="OnOk" IsDefault="True" IsCancel="True"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
