<UserControl x:Class="ZapretUI.Controls.DonateBlock"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf">
    <!-- App-styled donate card: rounded surface, muted header, QR tile, accent link -->
    <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrush2}"
            BorderThickness="1" CornerRadius="12" Padding="14" HorizontalAlignment="Left"
            Cursor="Hand" MouseLeftButtonUp="OnOpen" ToolTip="Открыть страницу поддержки">
        <Border.Style>
            <Style TargetType="Border">
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <StackPanel HorizontalAlignment="Center">
            <TextBlock Text="ПОДДЕРЖАТЬ АВТОРА" Style="{StaticResource Muted}" FontSize="10.5"
                       FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,10"/>

            <!-- White tile keeps the QR scannable on the dark theme -->
            <Border Background="White" CornerRadius="8" Padding="7" HorizontalAlignment="Center">
                <Image Source="/Assets/donate-qr.png" Width="112" Height="112"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
            </Border>

            <!-- Heart is a sibling emoji:TextBlock (Emoji.Wpf only colorizes its own Text,
                 not runs inside a Hyperlink); the whole card stays clickable via OnOpen. -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                <TextBlock FontSize="12.5" FontWeight="SemiBold" VerticalAlignment="Center">
                    <Hyperlink x:Name="Link" NavigateUri="https://web.tribute.tg/d/HFh"
                               RequestNavigate="OnNavigate" TextDecorations="{x:Null}"
                               Foreground="{StaticResource AccentBrush}"
                               ToolTip="https://web.tribute.tg/d/HFh">
                        <Hyperlink.Style>
                            <Style TargetType="Hyperlink">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="TextDecorations" Value="Underline"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Hyperlink.Style>
                        Поддержать автора
                    </Hyperlink>
                </TextBlock>
                <emoji:TextBlock Text="&#160;💚" FontSize="12.5" FontWeight="SemiBold"
                                 VerticalAlignment="Center"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
