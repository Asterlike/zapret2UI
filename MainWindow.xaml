<Window x:Class="Zapret2UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:ctl="clr-namespace:Zapret2UI.Controls"
        xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
        Title="Zapret2UI" Height="720" Width="1280" MinHeight="580" MinWidth="880"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" ResizeMode="CanResize"
        Icon="Assets/app.ico"
        Background="{StaticResource BgBrush}"
        FontFamily="{StaticResource UiFont}">

    <Window.Resources>
        <!-- Segmented control for Простой / Расширенный -->
        <Style x:Key="ModeSegment" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource FgMutedBrush}"/>
            <Setter Property="Padding" Value="16,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="b" CornerRadius="6" Background="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="46" ResizeBorderThickness="6"
                            CornerRadius="0" GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border x:Name="RootBorder" BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1">
        <Border.Background>
            <RadialGradientBrush GradientOrigin="0.5,-0.1" Center="0.5,-0.1" RadiusX="0.9" RadiusY="0.8">
                <GradientStop Color="#FF0F1218" Offset="0"/>
                <GradientStop Color="#FF080A0E" Offset="0.6"/>
                <GradientStop Color="#FF060709" Offset="1"/>
            </RadialGradientBrush>
        </Border.Background>
        <!-- ContentRoot carries the app-wide UI-scale ScaleTransform (see MainWindow.ApplyUiScale) -->
        <Grid x:Name="ContentRoot">
            <Grid.RowDefinitions>
                <RowDefinition Height="46"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ============ Decorative background blooms (violet · concept C) ============ -->
            <Grid Grid.RowSpan="2" IsHitTestVisible="False" ClipToBounds="True">
                <Ellipse Width="1000" Height="680" HorizontalAlignment="Center" VerticalAlignment="Top"
                         Margin="0,-200,0,0">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#2EA78BFA" Offset="0"/>
                            <GradientStop Color="#00080A0E" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>
                <Ellipse Width="760" Height="560" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                         Margin="0,0,-180,-160">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#186AA0FF" Offset="0"/>
                            <GradientStop Color="#00080A0E" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>
            </Grid>

            <!-- ============ Caption bar ============ -->
            <Grid Grid.Row="0" Background="Transparent">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                    <Image Source="/Assets/app.ico" Width="20" Height="20" Margin="0,0,10,0" VerticalAlignment="Center"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="Zapret2UI" FontFamily="{StaticResource DisplayFont}" FontWeight="Bold" FontSize="14"
                               VerticalAlignment="Center"/>
                    <Border CornerRadius="6" BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1"
                            Padding="7,2" Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="DPI bypass" FontSize="11" Foreground="{StaticResource FgMutedBrush}"/>
                    </Border>
                    <TextBlock Text="{Binding AppVersion}" FontSize="11" FontFamily="{StaticResource MonoFont}"
                               Foreground="{StaticResource Muted2Brush}"
                               VerticalAlignment="Center" Margin="8,1,0,0"/>
                    <!-- App-update badge: shown only when a newer ZapretUI release exists; opens the page -->
                    <Button Command="{Binding OpenAppReleaseCommand}" VerticalAlignment="Center" Margin="10,0,0,0"
                            Cursor="Hand" shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            Visibility="{Binding AppUpdateAvailable, Converter={StaticResource BoolToVis}}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="#26F5A623" BorderBrush="{StaticResource WarnBrush}" BorderThickness="1"
                                        CornerRadius="6" Padding="8,2">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#x2B07;" FontSize="11" Foreground="{StaticResource WarnBrush}"
                                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="{Binding AppUpdateText}" FontSize="11"
                                                   Foreground="{StaticResource WarnBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Apply-strategy pill: lives in the caption bar so a pending preset switch can be
                         applied from ANY tab without returning to Главная. Shows only when pending. -->
                    <Button Command="{Binding ApplyStrategyCommand}" VerticalAlignment="Center" Margin="10,0,0,0"
                            Cursor="Hand" shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            ToolTip="Перезапустить обход с выбранным пресетом"
                            Visibility="{Binding IsStrategyChangePending, Converter={StaticResource BoolToVis}}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="#1A34D399" BorderBrush="{StaticResource SuccessBrush}" BorderThickness="1"
                                        CornerRadius="6" Padding="8,2">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#x21BB;" FontSize="12" Foreground="{StaticResource SuccessBrush}"
                                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock FontSize="11" Foreground="{StaticResource SuccessBrush}" VerticalAlignment="Center"
                                                   Text="{Binding SelectedPreset.Name, StringFormat='Применить: {0}'}"/>
                                    </StackPanel>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <Border HorizontalAlignment="Center" VerticalAlignment="Center" CornerRadius="8"
                        Background="{StaticResource BgBrush}" BorderBrush="{StaticResource BorderBrush2}"
                        BorderThickness="1" Padding="3"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton Style="{StaticResource ModeSegment}" Content="Простой"
                                     IsChecked="{Binding IsSimpleMode, Mode=TwoWay}"/>
                        <RadioButton Style="{StaticResource ModeSegment}" Content="Расширенный"
                                     IsChecked="{Binding IsSimpleMode, Converter={StaticResource InverseBool}, Mode=TwoWay}"/>
                    </StackPanel>
                </Border>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button x:Name="MinButton" Style="{StaticResource CaptionButton}" Click="OnMinimize">
                        <TextBlock Text="&#xE921;" FontFamily="{StaticResource IconFont}" FontSize="11"/>
                    </Button>
                    <Button x:Name="MaxButton" Style="{StaticResource CaptionButton}" Click="OnMaximizeRestore">
                        <TextBlock Text="&#xE922;" FontFamily="{StaticResource IconFont}" FontSize="11"/>
                    </Button>
                    <Button x:Name="CloseButton" Style="{StaticResource CloseButton}" Click="OnCloseClick">
                        <TextBlock Text="&#xE8BB;" FontFamily="{StaticResource IconFont}" FontSize="11"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- ============ Body: top tabs (Главная — first; strip hidden in Simple) ============ -->
            <TabControl x:Name="MainTabs" Grid.Row="1" Style="{StaticResource TopTabs}"
                        SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}"
                        SelectionChanged="OnTabsSelectionChanged">
                <TabControl.Resources>
                    <Style TargetType="TabItem" BasedOn="{StaticResource TopTabItem}"/>
                </TabControl.Resources>

                <!-- ===================== Главная ===================== -->
                <TabItem Header="Главная">
                    <Grid>
                        <!-- gear → Настройки -->
                        <Button Command="{Binding GoToSettingsCommand}" Style="{StaticResource GhostButton}"
                                HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,22,26,0"
                                Width="40" Height="40" Padding="0" ToolTip="Настройки">
                            <TextBlock Text="&#xE713;" FontFamily="{StaticResource IconFont}" FontSize="16"/>
                        </Button>

                        <!-- top banner (apply-strategy) -->
                        <StackPanel VerticalAlignment="Top" HorizontalAlignment="Center" MaxWidth="540" Margin="24,20,24,0">
                            <Border CornerRadius="10" Padding="12,10" Margin="0,0,0,10"
                                    Background="#1A34D399" BorderBrush="{StaticResource SuccessBrush}" BorderThickness="1"
                                    Visibility="{Binding IsStrategyChangePending, Converter={StaticResource BoolToVis}}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0"
                                               Style="{StaticResource Muted}" FontSize="11.5" TextWrapping="Wrap"
                                               Text="Чтобы применить выбранный пресет, нужно перезапустить движок."/>
                                    <Button Grid.Column="1" Content="Сменить стратегию"
                                            Command="{Binding ApplyStrategyCommand}"
                                            Style="{StaticResource StartStopButton}" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!-- centered status hero + one big action button -->
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="440" Margin="24"
                                    Opacity="0" RenderTransformOrigin="0.5,0.5">
                            <StackPanel.RenderTransform><TranslateTransform x:Name="homeSlide" Y="12"/></StackPanel.RenderTransform>
                            <StackPanel.Triggers>
                                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4"/>
                                            <DoubleAnimation Storyboard.TargetName="homeSlide" Storyboard.TargetProperty="Y"
                                                             From="12" To="0" Duration="0:0:0.4">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </StackPanel.Triggers>

                            <!-- status dot + word -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,18">
                                <Ellipse Width="9" Height="9" VerticalAlignment="Center" Margin="0,0,10,0"
                                         Fill="{Binding State, Converter={StaticResource StateToBrush}}">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                    <DataTrigger.EnterActions>
                                                        <BeginStoryboard Name="HomeDot">
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                    From="1" To="0.3" Duration="0:0:1"
                                                                    AutoReverse="True" RepeatBehavior="Forever"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.EnterActions>
                                                    <DataTrigger.ExitActions>
                                                        <StopStoryboard BeginStoryboardName="HomeDot"/>
                                                    </DataTrigger.ExitActions>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="{Binding State, Converter={StaticResource StateToText}}"
                                           FontFamily="{StaticResource DisplayFont}" FontSize="13" FontWeight="Bold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource FgMutedBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>

                            <!-- one big action button (routes by mode). The compact dot+label above is the
                                 sole status now (no redundant 30pt headline) — the button itself names the action. -->
                            <Button Command="{Binding HomeToggleCommand}" Height="56" Width="300"
                                    HorizontalAlignment="Center" Margin="0,22,0,0">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource StartStopButton}">
                                        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                        <Setter Property="FontSize" Value="16"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <TextBlock FontFamily="{StaticResource DisplayFont}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="&#x25B6;  Включить обход"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                    <Setter Property="Text" Value="&#x25A0;  Остановить обход"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Button>

                            <emoji:TextBlock Text="{Binding SimpleStatus}" Style="{StaticResource Muted}" FontSize="13"
                                       HorizontalAlignment="Center" TextAlignment="Center" Margin="0,20,0,0"/>

                            <!-- scope chips -->
                            <TextBlock Text="ЧТО ПОДОБРАТЬ" Style="{StaticResource Muted}" FontSize="11"
                                       HorizontalAlignment="Center" Margin="0,26,0,10"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <RadioButton Style="{StaticResource ChipButton}" IsChecked="{Binding ScopeBoth, Mode=TwoWay}">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource Icon.Discord}" Fill="{StaticResource Brand.Discord}" Width="15" Height="15" Stretch="Uniform" VerticalAlignment="Center"/>
                                        <Path Data="{StaticResource Icon.YouTube}" Fill="{StaticResource Brand.YouTube}" Width="15" Height="15" Stretch="Uniform" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                        <TextBlock Text="Discord + YouTube" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    </StackPanel>
                                </RadioButton>
                                <RadioButton Style="{StaticResource ChipButton}" IsChecked="{Binding ScopeDiscord, Mode=TwoWay}">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource Icon.Discord}" Fill="{StaticResource Brand.Discord}" Width="15" Height="15" Stretch="Uniform" VerticalAlignment="Center"/>
                                        <TextBlock Text="Discord" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    </StackPanel>
                                </RadioButton>
                                <RadioButton Style="{StaticResource ChipButton}" IsChecked="{Binding ScopeYouTube, Mode=TwoWay}">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource Icon.YouTube}" Fill="{StaticResource Brand.YouTube}" Width="15" Height="15" Stretch="Uniform" VerticalAlignment="Center"/>
                                        <TextBlock Text="YouTube" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    </StackPanel>
                                </RadioButton>
                            </StackPanel>
                            <TextBlock Text="{Binding SimpleGoalHint}" Style="{StaticResource Muted}" FontSize="11.5"
                                       HorizontalAlignment="Center" TextAlignment="Center" Margin="0,8,0,0"/>

                            <!-- Two ways to a working strategy. Подбор is primary (it tries proven
                                 strategies → more stable); генерация is the fallback that builds from scratch. -->
                            <Button Command="{Binding RunAutoSelectCommand}" Style="{StaticResource PrimaryButton}"
                                    Width="300" Height="44" Margin="0,18,0,0" HorizontalAlignment="Center"
                                    ToolTip="Перебирает проверенные стратегии и оставляет ту, что открывает выбранные сервисы. Стабильнее генерации — начните с неё. Занимает минуту-другую.">
                                <emoji:TextBlock Text="🔎  Подобрать стратегию" Foreground="White" FontWeight="SemiBold"/>
                            </Button>
                            <Button Command="{Binding GenerateStrategyCommand}" Style="{StaticResource GhostButton}"
                                    Width="300" Margin="0,8,0,0" HorizontalAlignment="Center"
                                    ToolTip="Собирает стратегию с нуля под вашего провайдера — отдельно под Discord и YouTube. Дольше и менее предсказуемо; используйте, если подбор не помог.">
                                <emoji:TextBlock Text="✨  Сгенерировать стратегию"/>
                            </Button>
                            <TextBlock Text="Сначала «Подобрать» — так стабильнее. «Сгенерировать» — если подбор не пробил."
                                       Style="{StaticResource Muted}" FontSize="11" TextWrapping="Wrap" MaxWidth="320"
                                       HorizontalAlignment="Center" TextAlignment="Center" Margin="0,10,0,0"/>

                            <ProgressBar Value="{Binding UpdateProgress, Mode=OneWay}" Maximum="1" Margin="0,16,0,0"
                                         Visibility="{Binding IsUpdating, Converter={StaticResource BoolToVis}}"/>
                            <TextBlock Text="{Binding UpdateStatus}" Style="{StaticResource Muted}" Margin="0,8,0,0"
                                       HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"
                                       Visibility="{Binding IsUpdating, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>

                        <!-- Left column: Telegram card (top) + donate (bottom) share one DockPanel so they
                             can never overlap. The card is docked first, so it keeps its full height and
                             a tight, compact layout fits the default window size. tg-ws-proxy is independent
                             of the winws2 engine, so the card stays visible in Simple and Advanced alike. -->
                        <DockPanel HorizontalAlignment="Left" Width="248" Margin="24,20,0,22" LastChildFill="False">
                            <Border DockPanel.Dock="Top" Style="{StaticResource Card}" Padding="16">
                                <StackPanel>
                                    <!-- Header row: icon + title + the on/off toggle (moved here from the Home
                                         hero so it sits with Открыть/Копировать). Shown in both modes. -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Path Grid.Column="0" Data="{StaticResource Icon.Telegram}" Fill="{StaticResource Brand.Telegram}"
                                              Width="22" Height="22" Stretch="Uniform" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="Telegram" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center" Margin="9,0,0,0"/>
                                        <CheckBox Grid.Column="2" Style="{StaticResource ToggleSwitch}" VerticalAlignment="Center"
                                                  IsChecked="{Binding IsTelegramProxyEnabled, Mode=TwoWay}"
                                                  ToolTip="Включить встроенный прокси для Telegram"/>
                                    </Grid>
                                    <Border Background="#1FFFFFFF" CornerRadius="8" Padding="10,7" Margin="0,10,0,0">
                                        <StackPanel>
                                            <TextBlock Text="Адрес (MTProto-прокси)" Style="{StaticResource Muted}" FontSize="10.5"/>
                                            <TextBlock Text="{Binding TelegramProxyEndpoint}" FontSize="12.5" FontWeight="SemiBold" Margin="0,1,0,0"/>
                                            <TextBlock Text="Секрет" Style="{StaticResource Muted}" FontSize="10.5" Margin="0,5,0,0"/>
                                            <TextBlock Text="{Binding TelegramProxySecret}" FontSize="10.5" TextWrapping="Wrap" Margin="0,1,0,0"/>
                                        </StackPanel>
                                    </Border>
                                    <!-- open + copy on one row -->
                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Content="Открыть" Command="{Binding OpenTelegramProxyLinkCommand}"
                                                Style="{StaticResource GhostButton}" ToolTip="Открыть в Telegram"/>
                                        <Button Grid.Column="2" Content="Копировать" Command="{Binding CopyTelegramProxyLinkCommand}"
                                                Style="{StaticResource GhostButton}" ToolTip="Скопировать ссылку (tg://proxy)"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Instruction entry (both modes), right under the Telegram card -->
                            <Button DockPanel.Dock="Top" Style="{StaticResource GhostButton}" Margin="0,12,0,0"
                                    HorizontalContentAlignment="Center"
                                    Command="{Binding OpenLinkCommand}"
                                    CommandParameter="https://github.com/Asterlike/zapret2UI/blob/main/README.md#-быстрый-старт-для-новичка"
                                    ToolTip="Открыть инструкцию (быстрый старт) на GitHub">
                                <emoji:TextBlock Text="📖  Инструкция"/>
                            </Button>

                            <!-- Donate (bottom of the left column, both modes) -->
                            <ctl:DonateBlock DockPanel.Dock="Bottom" HorizontalAlignment="Left" Margin="0,16,0,0"/>
                        </DockPanel>
                    </Grid>
                </TabItem>

                <!-- ===================== Стратегии ===================== -->
                <TabItem Header="Стратегии">
                    <Grid Margin="24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <DockPanel Grid.Row="0" Margin="2,0,0,16">
                            <Button DockPanel.Dock="Right" Style="{StaticResource GhostButton}" VerticalAlignment="Top"
                                    Command="{Binding OpenLinkCommand}"
                                    CommandParameter="https://github.com/Asterlike/zapret2UI/blob/main/manual_zapret2UI.md#5-встроенные-стратегии"
                                    ToolTip="Открыть раздел «Встроенные стратегии» в инструкции">
                                <emoji:TextBlock Text="📖  Инструкция"/>
                            </Button>
                            <StackPanel>
                                <TextBlock Text="Стратегии" Style="{StaticResource H1}"/>
                                <TextBlock Style="{StaticResource Muted}" Margin="0,3,0,0"
                                           Text="Готовые способы обхода Discord и YouTube. Выберите слева — справа описание. Здесь же ваши стратегии из подбора и генерации."/>
                            </StackPanel>
                        </DockPanel>
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="360"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource Card}" Padding="8" Margin="0,0,16,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                            <ListBox Grid.Row="0" ItemsSource="{Binding PresetsView}" SelectedItem="{Binding SelectedPreset}"
                                     ItemContainerStyle="{StaticResource SelectableItem}">
                                <ListBox.GroupStyle>
                                    <GroupStyle>
                                        <GroupStyle.HeaderTemplate>
                                            <DataTemplate>
                                                <Border Margin="2,12,2,6" Padding="0,0,0,8"
                                                        BorderBrush="{StaticResource BorderBrush2}" BorderThickness="0,0,0,1">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Border Width="3" Height="13" CornerRadius="2" Margin="0,0,8,0"
                                                                Background="{StaticResource AccentBrush}" VerticalAlignment="Center"/>
                                                        <emoji:TextBlock Text="{Binding Name}" FontSize="11" FontWeight="Bold"
                                                                   Foreground="{StaticResource FgMutedBrush}" VerticalAlignment="Center"/>
                                                        <Border CornerRadius="6" Background="{StaticResource AccentSoftBrush}"
                                                                Padding="6,1" Margin="8,0,0,0" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding ItemCount}" FontSize="10" FontWeight="Bold"
                                                                       FontFamily="{StaticResource MonoFont}"
                                                                       Foreground="{StaticResource AccentBrush}"/>
                                                        </Border>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </GroupStyle.HeaderTemplate>
                                    </GroupStyle>
                                </ListBox.GroupStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <!-- ToolTip carries the full name so long names (e.g. ALT10 vs ALT11)
                                             stay distinguishable even when the row trims them with an ellipsis. -->
                                        <StackPanel ToolTip="{Binding Name}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <!-- ★ marks the recommended strategy -->
                                                <TextBlock Grid.Column="0" Text="★  " FontWeight="Bold" VerticalAlignment="Center"
                                                           Foreground="{StaticResource AccentBrush}"
                                                           Visibility="{Binding IsRecommended, Converter={StaticResource BoolToVis}}"/>
                                                <emoji:TextBlock Grid.Column="1" Text="{Binding PrimaryLabel}" FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis" Margin="0,0,64,0"/>
                                                <!-- "ВКЛЮЧЁН" badge — visible only on the actually-running preset -->
                                                <Border Grid.ColumnSpan="2" CornerRadius="5" Padding="6,1" HorizontalAlignment="Right"
                                                        Background="#2634D399" VerticalAlignment="Center">
                                                    <Border.Visibility>
                                                        <MultiBinding Converter="{StaticResource RefEqualsToVis}">
                                                            <Binding Path="."/>
                                                            <Binding Path="DataContext.RunningPreset"
                                                                     RelativeSource="{RelativeSource AncestorType=ListBox}"/>
                                                        </MultiBinding>
                                                    </Border.Visibility>
                                                    <TextBlock Text="ВКЛЮЧЁН" FontSize="9.5" FontWeight="Bold"
                                                               Foreground="{StaticResource SuccessBrush}"/>
                                                </Border>
                                            </Grid>
                                            <TextBlock Text="{Binding SecondaryLabel}" Style="{StaticResource Muted}"
                                                       FontSize="11.5" TextTrimming="CharacterEllipsis" MaxHeight="32"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <Button Grid.Row="1" Command="{Binding OpenHowItWorksCommand}"
                                    Style="{StaticResource GhostButton}" Margin="4,8,4,4" HorizontalAlignment="Stretch">
                                <emoji:TextBlock Text="❔  Как это работает"/>
                            </Button>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource Card}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <emoji:TextBlock Grid.Row="0" Text="{Binding SelectedPreset.Name, FallbackValue='Выберите пресет'}"
                                           Style="{StaticResource H2}" TextWrapping="Wrap"/>

                                <!-- Row 1: friendly tagline + «рекомендуемая» badge — fills what used to be dead
                                     space under the technical name. -->
                                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,7,0,0">
                                    <Border CornerRadius="6" Background="{StaticResource AccentSoftBrush}" Padding="8,2" Margin="0,0,8,0"
                                            VerticalAlignment="Center"
                                            Visibility="{Binding SelectedPreset.IsRecommended, Converter={StaticResource BoolToVis}}">
                                        <emoji:TextBlock Text="★ Рекомендуемая" FontSize="11" FontWeight="Bold"
                                                   Foreground="{StaticResource AccentBrush}"/>
                                    </Border>
                                    <emoji:TextBlock Text="{Binding SelectedPreset.Tagline}" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center"
                                               Visibility="{Binding SelectedPreset.HasTagline, Converter={StaticResource BoolToVis}}"/>
                                </StackPanel>

                                <!-- Row 2 holds EITHER the readable description (default) OR the raw-args editor.
                                     The editor is opt-in via the «Аргументы движка» button (declutter). -->
                                <Grid Grid.Row="2" Margin="0,10,0,0">
                                    <!-- Default view: description scrolls at the top, a help + documentation
                                         card is pinned at the bottom — so a short description no longer leaves
                                         a big void, and the pane reads top-to-bottom. -->
                                    <ScrollViewer Visibility="{Binding ShowPresetArgs, Converter={StaticResource BoolToVis}, ConverterParameter=invert}"
                                                  VerticalScrollBarVisibility="Auto">
                                        <!-- Description + help card grouped at the TOP so a short description no longer
                                             leaves a void sandwiched between two blocks; trailing space sits below. -->
                                        <StackPanel>
                                            <TextBlock Text="{Binding SelectedPreset.Description}" TextWrapping="Wrap"
                                                       FontSize="13.5" LineHeight="20" Foreground="{StaticResource FgBrush}"/>
                                            <Border CornerRadius="10" Padding="14,12" Margin="0,16,0,0"
                                                    Background="{StaticResource BgBrush}" BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1">
                                                <StackPanel>
                                                    <TextBlock Text="Не заработало?" FontWeight="SemiBold"/>
                                                    <TextBlock Style="{StaticResource Muted}" FontSize="12" TextWrapping="Wrap" Margin="0,4,0,0"
                                                               Text="Стратегии зависят от провайдера. Если этот пресет не пробивает — попробуйте другие из списка. Если ничего не заходит — вкладка «Диагностика» → «Подобрать лучшую» подберёт рабочую стратегию под вашего оператора."/>
                                                    <WrapPanel Margin="0,10,0,0">
                                                        <Button Command="{Binding OpenHowItWorksCommand}"
                                                                Style="{StaticResource GhostButton}" Margin="0,0,8,0">
                                                            <emoji:TextBlock Text="❔  Как это работает"/>
                                                        </Button>
                                                        <Button Command="{Binding OpenLinkCommand}"
                                                                CommandParameter="https://github.com/Asterlike/zapret2UI/blob/main/manual_zapret2UI.md#17-решение-проблем-и-коды-ошибок"
                                                                Style="{StaticResource GhostButton}"
                                                                ToolTip="Открыть раздел «Решение проблем и коды ошибок» в инструкции">
                                                            <emoji:TextBlock Text="📖  Инструкция"/>
                                                        </Button>
                                                    </WrapPanel>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </ScrollViewer>
                                    <!-- Opt-in: in-app args editor, styled as a terminal -->
                                    <Border Visibility="{Binding ShowPresetArgs, Converter={StaticResource BoolToVis}}"
                                            Background="{StaticResource BgBrush}" CornerRadius="12"
                                            BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1" ClipToBounds="True">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <!-- terminal title bar -->
                                            <Border Grid.Row="0" Background="#10FFFFFF" Padding="12,9"
                                                    BorderBrush="{StaticResource BorderBrush2}" BorderThickness="0,0,0,1">
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse Width="9" Height="9" Fill="#FFE2566A" Margin="0,0,6,0"/>
                                                    <Ellipse Width="9" Height="9" Fill="#FFF5C451" Margin="0,0,6,0"/>
                                                    <Ellipse Width="9" Height="9" Fill="#FF34D399" Margin="0,0,10,0"/>
                                                    <TextBlock Text="аргументы winws2 (по одному в строке)"
                                                               FontFamily="{StaticResource MonoFont}" FontSize="11"
                                                               Foreground="{StaticResource Muted2Brush}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                            <TextBox Grid.Row="1" Text="{Binding PresetArgsText, UpdateSourceTrigger=PropertyChanged}"
                                                     IsReadOnly="{Binding SelectedPresetEditable, Converter={StaticResource InverseBool}}"
                                                     AcceptsReturn="True" TextWrapping="NoWrap" Background="Transparent" BorderThickness="0"
                                                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                                     FontFamily="{StaticResource MonoFont}" FontSize="12"/>
                                            <!-- fully-expanded command that will actually run -->
                                            <StackPanel Grid.Row="2" Margin="12,8,12,12">
                                                <TextBlock Text="ЗАПУСК" Style="{StaticResource Muted}" FontSize="10"/>
                                                <TextBlock Text="{Binding CommandPreview}" FontFamily="{StaticResource MonoFont}"
                                                           FontSize="11.5" Foreground="{StaticResource FgMutedBrush}"
                                                           TextWrapping="Wrap" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Grid>

                                <StackPanel Grid.Row="3" Margin="0,14,0,0">
                                    <!-- Apply-strategy banner: a strategy change needs an engine restart,
                                         so the user confirms it explicitly here. -->
                                    <Border CornerRadius="8" Padding="12,10" Margin="0,0,0,12"
                                            Background="#1A34D399" BorderBrush="{StaticResource SuccessBrush}" BorderThickness="1"
                                            Visibility="{Binding IsStrategyChangePending, Converter={StaticResource BoolToVis}}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                                                <TextBlock Text="Выбрана другая стратегия" FontWeight="SemiBold" FontSize="12.5"/>
                                                <TextBlock Style="{StaticResource Muted}" FontSize="11.5" TextWrapping="Wrap"
                                                           Text="{Binding RunningPresetName, StringFormat='Сейчас включён: {0}. Смена стратегии требует перезапуска движка.'}"/>
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="Сменить стратегию"
                                                    Command="{Binding ApplyStrategyCommand}"
                                                    Style="{StaticResource StartStopButton}" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>

                                    <StackPanel Orientation="Horizontal">
                                        <Button Command="{Binding TogglePresetArgsCommand}"
                                                Style="{StaticResource GhostButton}" Margin="0,0,8,0">
                                            <TextBlock>
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="Аргументы движка"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ShowPresetArgs}" Value="True">
                                                                <Setter Property="Text" Value="Скрыть аргументы"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Button>
                                        <Button Content="Дублировать" Command="{Binding DuplicatePresetCommand}"
                                                Style="{StaticResource GhostButton}" Margin="0,0,8,0"/>
                                        <Button Content="Сохранить" Command="{Binding SavePresetCommand}"
                                                Style="{StaticResource GhostButton}" Margin="0,0,8,0"/>
                                        <Button Content="Удалить" Command="{Binding DeletePresetCommand}"
                                                Style="{StaticResource GhostButton}"/>
                                        <TextBlock Text="Встроенный — дублируйте для правки"
                                                   Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="14,0,0,0"
                                                   Visibility="{Binding SelectedPresetEditable, Converter={StaticResource BoolToVis}, ConverterParameter=invert}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>
                        </Grid>
                    </Grid>
                </TabItem>

                <!-- Хостлисты -->
                <TabItem Header="Хостлисты">
                    <Grid Margin="24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <DockPanel Grid.Row="0" Margin="2,0,0,16">
                            <Button DockPanel.Dock="Right" Style="{StaticResource GhostButton}" VerticalAlignment="Top"
                                    Command="{Binding OpenLinkCommand}"
                                    CommandParameter="https://github.com/Asterlike/zapret2UI/blob/main/manual_zapret2UI.md#8-хостлисты-свои-цели-и-обход-по-ip"
                                    ToolTip="Открыть раздел «Хостлисты, свои цели и обход по IP» в инструкции">
                                <emoji:TextBlock Text="📖  Инструкция"/>
                            </Button>
                            <StackPanel>
                                <TextBlock Text="Хостлисты" Style="{StaticResource H1}"/>
                                <TextBlock Style="{StaticResource Muted}" Margin="0,3,0,0"
                                           Text="Списки доменов, к которым применяется обход. Один домен — одна строка."/>
                            </StackPanel>
                        </DockPanel>
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="240"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource Card}" Padding="8" Margin="0,0,16,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <ListBox Grid.Row="0" ItemsSource="{Binding Hostlists}"
                                         SelectedItem="{Binding SelectedHostlist}"
                                         ItemContainerStyle="{StaticResource SelectableItem}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="28" Height="28" CornerRadius="8" VerticalAlignment="Center"
                                                        Background="{StaticResource AccentSoftBrush}"
                                                        BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1">
                                                    <emoji:TextBlock Text="📄" FontSize="13"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock Text="{Binding}" FontFamily="{StaticResource MonoFont}"
                                                           FontSize="13" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <Button Grid.Row="1" Content="+ Новый список" Command="{Binding NewHostlistCommand}"
                                        Style="{StaticResource GhostButton}" Margin="4,8,4,4"/>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource Card}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="{Binding SelectedHostlist, FallbackValue='Выберите или создайте список'}"
                                           FontFamily="{StaticResource MonoFont}" FontSize="16" FontWeight="Bold"/>

                                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,12">
                                    <TextBox Width="300" Text="{Binding NewDomain, UpdateSourceTrigger=PropertyChanged}"/>
                                    <Button Content="Добавить домен" Command="{Binding AddDomainCommand}"
                                            Style="{StaticResource GhostButton}" Margin="8,0,0,0"/>
                                </StackPanel>

                                <TextBox Grid.Row="2" Text="{Binding HostlistContent, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True" TextWrapping="NoWrap" Background="{StaticResource BgBrush}"
                                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                         FontFamily="{StaticResource MonoFont}" FontSize="12.5"/>

                                <StackPanel Grid.Row="3" Margin="0,14,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Сохранить список" Command="{Binding SaveHostlistCommand}"
                                                Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"/>
                                        <Button Content="Удалить список" Command="{Binding DeleteHostlistCommand}"
                                                Style="{StaticResource GhostButton}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>
                        </Grid>
                    </Grid>
                </TabItem>

                <!-- Диагностика: автоподбор/генератор + матрица -->
                <TabItem Header="Диагностика">
                    <Grid Margin="24">
                        <Grid.Resources>
                            <CollectionViewSource x:Key="GroupedDiag" Source="{Binding DiagRows}">
                                <CollectionViewSource.GroupDescriptions>
                                    <PropertyGroupDescription PropertyName="Group"/>
                                </CollectionViewSource.GroupDescriptions>
                            </CollectionViewSource>
                        </Grid.Resources>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" MinWidth="360" MaxWidth="480"/>
                            <ColumnDefinition Width="3*" MinWidth="440"/>
                        </Grid.ColumnDefinitions>

                        <!-- LEFT: подбор / цели / генерация — scrolls as a whole, scales with window -->
                        <ScrollViewer Grid.Column="0" Margin="0,0,16,0" VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel>

                            <!-- Card: auto-select + generate + scope + results -->
                            <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <DockPanel>
                                    <Button DockPanel.Dock="Right" Style="{StaticResource GhostButton}" VerticalAlignment="Center"
                                            Command="{Binding OpenLinkCommand}"
                                            CommandParameter="https://github.com/Asterlike/zapret2UI/blob/main/manual_zapret2UI.md#6-автоподбор-и-генерация"
                                            ToolTip="Открыть раздел «Автоподбор и генерация» в инструкции">
                                        <emoji:TextBlock Text="📖  Инструкция"/>
                                    </Button>
                                    <TextBlock Text="Проверка и авто-подбор" Style="{StaticResource H2}" VerticalAlignment="Center"/>
                                </DockPanel>
                                <TextBlock Style="{StaticResource Muted}" Margin="0,6,0,0" TextWrapping="Wrap"
                                           Text="«Подобрать лучшую» ищет рабочую стратегию по выбранной цели, «Диагностика» — показывает текущую доступность."/>

                                <!-- Scope -->
                                <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                                    <TextBlock Text="ЦЕЛЬ ПОДБОРА" Style="{StaticResource Muted}" FontSize="11"
                                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <Border CornerRadius="8" Background="{StaticResource BgBrush}"
                                            BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1" Padding="3">
                                        <StackPanel Orientation="Horizontal">
                                            <RadioButton Style="{StaticResource ModeSegment}" IsChecked="{Binding ScopeBoth, Mode=TwoWay}">
                                                <StackPanel Orientation="Horizontal">
                                                    <Path Data="{StaticResource Icon.Discord}" Fill="{StaticResource Brand.Discord}" Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center"/>
                                                    <Path Data="{StaticResource Icon.YouTube}" Fill="{StaticResource Brand.YouTube}" Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                                    <TextBlock Text="DC + YT" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                                </StackPanel>
                                            </RadioButton>
                                            <RadioButton Style="{StaticResource ModeSegment}" IsChecked="{Binding ScopeDiscord, Mode=TwoWay}">
                                                <StackPanel Orientation="Horizontal">
                                                    <Path Data="{StaticResource Icon.Discord}" Fill="{StaticResource Brand.Discord}" Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Discord" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                                </StackPanel>
                                            </RadioButton>
                                            <RadioButton Style="{StaticResource ModeSegment}" IsChecked="{Binding ScopeYouTube, Mode=TwoWay}">
                                                <StackPanel Orientation="Horizontal">
                                                    <Path Data="{StaticResource Icon.YouTube}" Fill="{StaticResource Brand.YouTube}" Width="13" Height="13" Stretch="Uniform" VerticalAlignment="Center"/>
                                                    <TextBlock Text="YouTube" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                                </StackPanel>
                                            </RadioButton>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- Actions (wrap — compact, flows to the left column width) -->
                                <WrapPanel Margin="0,14,0,0">
                                    <Button Content="Подобрать лучшую" Command="{Binding RunAutoSelectCommand}"
                                            Style="{StaticResource PrimaryButton}" Margin="0,0,8,8"
                                            Visibility="{Binding IsAutoSelecting, Converter={StaticResource BoolToVis}, ConverterParameter=invert}"/>
                                    <Button Content="Остановить подбор" Command="{Binding StopAutoSelectCommand}"
                                            Style="{StaticResource GhostButton}" Margin="0,0,8,8"
                                            Visibility="{Binding IsAutoSelecting, Converter={StaticResource BoolToVis}}"/>
                                    <Button Command="{Binding GenerateStrategyCommand}"
                                            Style="{StaticResource GhostButton}" Margin="0,0,8,8"
                                            ToolTip="Соберёт ПЕРСОНАЛЬНУЮ стратегию: тестирует компоненты и оптимизирует Discord и YouTube по отдельности, затем собирает в одно комбо (≈1 мин)."
                                            Visibility="{Binding IsGenerating, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
                                        <emoji:TextBlock Text="✨ Сгенерировать стратегию"/>
                                    </Button>
                                    <Button Content="Остановить генерацию" Command="{Binding StopAutoSelectCommand}"
                                            Style="{StaticResource GhostButton}" Margin="0,0,8,8"
                                            Visibility="{Binding IsGenerating, Converter={StaticResource BoolToVis}}"/>
                                    <Button Content="Диагностика" Command="{Binding RunDiagnosticsCommand}"
                                            Style="{StaticResource GhostButton}" Margin="0,0,8,8"
                                            Visibility="{Binding IsDiagnosing, Converter={StaticResource BoolToVis}, ConverterParameter=invert}"/>
                                    <Button Content="Остановить" Command="{Binding StopDiagnosticsCommand}"
                                            Style="{StaticResource GhostButton}" Margin="0,0,8,8"
                                            Visibility="{Binding IsDiagnosing, Converter={StaticResource BoolToVis}}"/>
                                    <Button Content="Проверка DPI" Command="{Binding RunDpiCheckCommand}"
                                            Style="{StaticResource GhostButton}" Margin="0,0,8,8"
                                            ToolTip="Определяет, режет ли провайдер по имени сайта (обрыв/RST или заморозка) и душит ли соединение по объёму/пакетам (TCP 16-20) — а не просто «сайт недоступен». Точнее всего с ВЫКЛЮЧЕННЫМ обходом."
                                            Visibility="{Binding IsDpiChecking, Converter={StaticResource BoolToVis}, ConverterParameter=invert}"/>
                                    <Button Content="Остановить" Command="{Binding StopDpiCheckCommand}"
                                            Style="{StaticResource GhostButton}" Margin="0,0,8,8"
                                            Visibility="{Binding IsDpiChecking, Converter={StaticResource BoolToVis}}"/>
                                </WrapPanel>

                                <emoji:TextBlock Text="{Binding AutoStatusText}" Style="{StaticResource Muted}"
                                           Margin="0,12,0,0" TextWrapping="Wrap"/>

                                <Border Background="#22F59E0B" CornerRadius="6" Padding="10,7" Margin="0,12,0,0">
                                    <TextBlock Text="{Binding DiagEngineNote}" TextWrapping="Wrap"
                                               FontSize="11.5" Foreground="#FFFBBF24"/>
                                </Border>

                                <Grid Margin="0,12,0,0">
                                    <TextBlock Text="{Binding DiagStatusText}" Style="{StaticResource Muted}"
                                               HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding DiagSummary}" FontWeight="SemiBold" FontSize="12.5"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>

                                <!-- DPI-signature verdict (обрыв/RST · заморозка · чисто · нет соединения) -->
                                <Border CornerRadius="8" Background="{StaticResource BgBrush}"
                                        BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1"
                                        Padding="12,10" Margin="0,12,0,0">
                                    <StackPanel>
                                        <TextBlock Text="{Binding DpiVerdictText}" TextWrapping="Wrap"
                                                   FontWeight="SemiBold" FontSize="12.5"
                                                   Foreground="{Binding DpiVerdictStatus, Converter={StaticResource DiagBrush}}"/>
                                        <TextBlock Text="{Binding DpiVerdictDetail}" TextWrapping="Wrap"
                                                   FontFamily="{StaticResource MonoFont}" FontSize="11.5"
                                                   Foreground="{StaticResource FgMutedBrush}" Margin="0,8,0,0"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                            </Border>

                            <!-- Свои цели (custom bypass targets) -->
                            <Border Style="{StaticResource Card}" Margin="0,16,0,0">
                                <StackPanel>
                                    <TextBlock Text="Свои цели" Style="{StaticResource H2}"/>
                                    <TextBlock Style="{StaticResource Muted}" Margin="0,6,0,0" TextWrapping="Wrap"
                                               Text="Добавьте свой сайт — приложение найдёт его поддомены и домены того же бренда на других зонах (yandex.ru → yandex.kz/md…), будет проверять их в диагностике, учитывать при подборе и генерации и применять к ним обход."/>

                                    <ItemsControl ItemsSource="{Binding CustomTargets}" Margin="0,12,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="9" Background="{StaticResource BgBrush}"
                                                        BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1"
                                                        Padding="12,9" Margin="0,0,0,6">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                                       FontFamily="{StaticResource MonoFont}" FontSize="13"/>
                                                            <TextBlock Text="{Binding Subtitle}" Style="{StaticResource Muted}" FontSize="11"/>
                                                        </StackPanel>
                                                        <Button Grid.Column="1" Content="Открыть" Style="{StaticResource GhostButton}"
                                                                Padding="10,5" FontSize="12" VerticalAlignment="Center"
                                                                Command="{Binding DataContext.OpenTargetCommand,
                                                                          RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding}"/>
                                                        <Button Grid.Column="2" Content="✕" Style="{StaticResource GhostButton}"
                                                                Padding="9,5" FontSize="12" MinWidth="0" Margin="6,0,0,0" VerticalAlignment="Center"
                                                                Command="{Binding DataContext.DeleteTargetCommand,
                                                                          RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding}"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <TextBlock FontSize="11.5" Margin="0,2,0,8" Text="Целей пока нет.">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource Muted}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CustomTargets.Count}" Value="0">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <Button Content="+ Добавить цель" Command="{Binding AddTargetCommand}"
                                            Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- RIGHT: матрица сервисов (тянется по ширине окна) -->
                        <Border Grid.Column="1" Style="{StaticResource Card}" Padding="6">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <!-- Column headers -->
                                <Grid Grid.Row="0" Margin="14,8,14,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="70"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="СЕРВИС / ТОЧКА" Style="{StaticResource Muted}" FontSize="11"/>
                                    <TextBlock Grid.Column="1" Text="HTTP" Style="{StaticResource Muted}" FontSize="11" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="TLS 1.2" Style="{StaticResource Muted}" FontSize="11" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="3" Text="TLS 1.3" Style="{StaticResource Muted}" FontSize="11" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="4" Text="ПИНГ" Style="{StaticResource Muted}" FontSize="11" HorizontalAlignment="Center"/>
                                </Grid>
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding Source={StaticResource GroupedDiag}}">
                                    <ItemsControl.GroupStyle>
                                        <GroupStyle>
                                            <GroupStyle.HeaderTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12.5"
                                                               Foreground="{StaticResource AccentBrush}" Margin="10,12,0,4"/>
                                                </DataTemplate>
                                            </GroupStyle.HeaderTemplate>
                                        </GroupStyle>
                                    </ItemsControl.GroupStyle>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="14,7" Margin="0,1" CornerRadius="6" Background="{StaticResource BgBrush}"
                                                    Opacity="0">
                                                <Border.Triggers>
                                                    <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                    From="0" To="1" Duration="0:0:0.3"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </EventTrigger>
                                                </Border.Triggers>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="70"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                                        <TextBlock Text="{Binding Host}" Style="{StaticResource Muted}" FontSize="10.5"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1" Text="{Binding Http, Converter={StaticResource DiagText}}"
                                                               Foreground="{Binding Http, Converter={StaticResource DiagBrush}}"
                                                               FontWeight="SemiBold" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Tls12, Converter={StaticResource DiagText}}"
                                                               Foreground="{Binding Tls12, Converter={StaticResource DiagBrush}}"
                                                               FontWeight="SemiBold" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="3" Text="{Binding Tls13, Converter={StaticResource DiagText}}"
                                                               Foreground="{Binding Tls13, Converter={StaticResource DiagBrush}}"
                                                               FontWeight="SemiBold" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="4" Text="{Binding PingText}"
                                                               Foreground="{Binding Ping, Converter={StaticResource DiagBrush}}"
                                                               FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- Логи -->
                <TabItem Header="Журнал">
                    <Grid Margin="24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <DockPanel Grid.Row="0" Margin="2,0,0,14">
                            <Button DockPanel.Dock="Right" Style="{StaticResource GhostButton}" VerticalAlignment="Center"
                                    ToolTip="Открыть раздел «Решение проблем и коды ошибок» в инструкции"
                                    Command="{Binding OpenLinkCommand}"
                                    CommandParameter="https://github.com/Asterlike/zapret2UI/blob/main/manual_zapret2UI.md#17-решение-проблем-и-коды-ошибок">
                                <emoji:TextBlock Text="📖  Инструкция"/>
                            </Button>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Журнал" Style="{StaticResource H1}" VerticalAlignment="Center"/>
                                <Border CornerRadius="6" BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1"
                                        Padding="7,2" Margin="12,2,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="--debug" FontFamily="{StaticResource MonoFont}" FontSize="11"
                                               Foreground="{StaticResource Muted2Brush}"/>
                                </Border>
                            </StackPanel>
                        </DockPanel>

                        <!-- Two separate journals: winws2 engine vs the Telegram proxy — split so a proxy
                             issue isn't lost in engine output. Each has its own Копировать / Очистить. -->
                        <TabControl Grid.Row="1" Style="{StaticResource SubTabs}">
                            <TabItem Style="{StaticResource SubTabItem}" Header="Движок">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,10">
                                        <Button Content="Копировать" Command="{Binding CopyLogCommand}"
                                                Style="{StaticResource GhostButton}" Margin="0,0,8,0"/>
                                        <Button Content="Очистить" Command="{Binding ClearLogCommand}"
                                                Style="{StaticResource GhostButton}"/>
                                    </StackPanel>
                                    <Border Grid.Row="1" Background="{StaticResource BgBrush}" CornerRadius="13" Padding="8"
                                            BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1">
                                        <ListBox x:Name="LogList" ItemsSource="{Binding LogLines}"
                                                 Style="{StaticResource LogListBox}"/>
                                    </Border>
                                </Grid>
                            </TabItem>

                            <TabItem Style="{StaticResource SubTabItem}" Header="Telegram">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,10">
                                        <Button Content="Копировать" Command="{Binding CopyProxyLogCommand}"
                                                Style="{StaticResource GhostButton}" Margin="0,0,8,0"/>
                                        <Button Content="Очистить" Command="{Binding ClearProxyLogCommand}"
                                                Style="{StaticResource GhostButton}"/>
                                    </StackPanel>
                                    <Border Grid.Row="1" Background="{StaticResource BgBrush}" CornerRadius="13" Padding="8"
                                            BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1">
                                        <ListBox x:Name="ProxyLogList" ItemsSource="{Binding ProxyLogLines}"
                                                 Style="{StaticResource LogListBox}"/>
                                    </Border>
                                </Grid>
                            </TabItem>
                        </TabControl>
                    </Grid>
                </TabItem>

                <!-- ===================== Telegram ===================== -->
                <TabItem Header="Telegram">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
                        <Grid MaxWidth="780" HorizontalAlignment="Left">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Margin="2,0,0,16">
                                <DockPanel>
                                    <Button DockPanel.Dock="Right" Style="{StaticResource GhostButton}" VerticalAlignment="Center"
                                            Command="{Binding OpenLinkCommand}"
                                            CommandParameter="https://github.com/Asterlike/zapret2UI/blob/main/manual_zapret2UI.md#11-встроенный-telegram-прокси"
                                            ToolTip="Открыть раздел «Встроенный Telegram-прокси» в инструкции">
                                        <emoji:TextBlock Text="📖  Инструкция"/>
                                    </Button>
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource Icon.Telegram}" Fill="{StaticResource Brand.Telegram}"
                                              Width="26" Height="26" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <TextBlock Text="Telegram" Style="{StaticResource H1}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DockPanel>
                                <TextBlock Style="{StaticResource Muted}" Margin="0,3,0,0" TextWrapping="Wrap"
                                           Text="Встроенный прокси проводит Telegram через WebSocket (Cloudflare) в обход блокировки по IP. Работает без прав администратора и не мешает основному обходу winws2 — Discord и YouTube по-прежнему обходит движок. Можно держать включённым всегда."/>
                            </StackPanel>

                            <Grid Grid.Row="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="18"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Left column: connection + settings -->
                                <StackPanel Grid.Column="0">
                                    <Border Style="{StaticResource Card}" Padding="18">
                                        <StackPanel>
                                            <TextBlock Text="Подключение" Style="{StaticResource H2}" Margin="0,0,0,12"/>
                                            <Button Content="{Binding TelegramProxyButtonText}" Command="{Binding EnableTelegramCommand}"
                                                    Style="{StaticResource StartStopButton}" HorizontalAlignment="Stretch"/>
                                            <Button Content="{Binding CheckTelegramProxyButtonText}" Command="{Binding CheckTelegramProxyCommand}"
                                                    Style="{StaticResource GhostButton}" HorizontalAlignment="Stretch" Margin="0,8,0,0"
                                                    ToolTip="Проверить, доходит ли прокси до Telegram (DoH, системный DNS, фронт-домены). Без прав администратора."/>
                                            <TextBlock Style="{StaticResource Muted}" FontSize="11.5" TextWrapping="Wrap" Margin="0,10,0,0"
                                                       Text="{Binding TelegramProxyStatus}"/>
                                            <Border Background="#1FFFFFFF" CornerRadius="8" Padding="12,9" Margin="0,12,0,0">
                                                <StackPanel>
                                                    <TextBlock Text="Адрес (MTProto-прокси)" Style="{StaticResource Muted}" FontSize="11"/>
                                                    <TextBlock Text="{Binding TelegramProxyEndpoint}" FontSize="14" FontWeight="SemiBold" Margin="0,2,0,0"/>
                                                    <TextBlock Text="Секрет" Style="{StaticResource Muted}" FontSize="11" Margin="0,7,0,0"/>
                                                    <TextBlock Text="{Binding TelegramProxySecret}" FontSize="11.5" TextWrapping="Wrap"
                                                               FontFamily="{StaticResource MonoFont}" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Border>
                                            <Grid Margin="0,12,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="8"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Button Grid.Column="0" Content="Открыть в Telegram" Command="{Binding OpenTelegramProxyLinkCommand}"
                                                        Style="{StaticResource PrimaryButton}" ToolTip="Добавить прокси в Telegram одним нажатием"/>
                                                <Button Grid.Column="2" Content="Копировать ссылку" Command="{Binding CopyTelegramProxyLinkCommand}"
                                                        Style="{StaticResource GhostButton}" ToolTip="Скопировать ссылку (tg://proxy)"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource Card}" Padding="18" Margin="0,16,0,0">
                                        <StackPanel>
                                            <TextBlock Text="Настройки" Style="{StaticResource H2}" Margin="0,0,0,10"/>
                                            <TextBlock Text="Локальный порт" Style="{StaticResource Muted}" FontSize="11.5"/>
                                            <TextBox Text="{Binding TelegramProxyPort, UpdateSourceTrigger=LostFocus}"
                                                     Width="120" HorizontalAlignment="Left" Margin="0,4,0,0"/>
                                            <TextBlock Style="{StaticResource Muted}" FontSize="11" TextWrapping="Wrap" Margin="0,6,0,0"
                                                       Text="По умолчанию 1443. Если порт занят — прокси возьмёт ближайший свободный. Смена порта перезапускает прокси."/>
                                            <CheckBox Content="Запускать прокси вместе с приложением" FontSize="12.5"
                                                      IsChecked="{Binding TelegramProxyAutostart}" Style="{StaticResource ToggleSwitch}"
                                                      Margin="0,14,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- Right column: minimal guide -->
                                <Border Grid.Column="2" Style="{StaticResource Card}" Padding="18" VerticalAlignment="Top">
                                    <StackPanel>
                                        <TextBlock Text="Как подключить" Style="{StaticResource H2}" Margin="0,0,0,14"/>

                                        <Grid Margin="0,0,0,13">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="22" Height="22" CornerRadius="11" VerticalAlignment="Top"
                                                    Background="{StaticResource AccentSoftBrush}">
                                                <TextBlock Text="1" Foreground="{StaticResource AccentBrush}" FontWeight="Bold" FontSize="12"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Grid.Column="1" Margin="10,0,0,0" Style="{StaticResource Muted}" FontSize="12.5" TextWrapping="Wrap"
                                                       Text="Включите прокси кнопкой «Включить» выше (или тумблером Telegram на «Главной»)."/>
                                        </Grid>

                                        <Grid Margin="0,0,0,13">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="22" Height="22" CornerRadius="11" VerticalAlignment="Top"
                                                    Background="{StaticResource AccentSoftBrush}">
                                                <TextBlock Text="2" Foreground="{StaticResource AccentBrush}" FontWeight="Bold" FontSize="12"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Grid.Column="1" Margin="10,0,0,0" Style="{StaticResource Muted}" FontSize="12.5" TextWrapping="Wrap"
                                                       Text="Нажмите «Открыть в Telegram» — прокси добавится сам. Подтвердите подключение в Telegram."/>
                                        </Grid>

                                        <Grid Margin="0,0,0,13">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="22" Height="22" CornerRadius="11" VerticalAlignment="Top"
                                                    Background="{StaticResource AccentSoftBrush}">
                                                <TextBlock Text="3" Foreground="{StaticResource AccentBrush}" FontWeight="Bold" FontSize="12"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Grid.Column="1" Margin="10,0,0,0" Style="{StaticResource Muted}" FontSize="12.5" TextWrapping="Wrap"
                                                       Text="Вручную (если не открылось): Telegram → Настройки → Данные и память → Прокси → Добавить прокси → MTProto. Впишите адрес и секрет."/>
                                        </Grid>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="22" Height="22" CornerRadius="11" VerticalAlignment="Top"
                                                    Background="{StaticResource AccentSoftBrush}">
                                                <TextBlock Text="4" Foreground="{StaticResource AccentBrush}" FontWeight="Bold" FontSize="12"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Grid.Column="1" Margin="10,0,0,0" Style="{StaticResource Muted}" FontSize="12.5" TextWrapping="Wrap"
                                                       Text="В Telegram загорится значок прокси — соединение идёт через обход. Голосовые звонки тоже работают."/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <!-- Настройки -->
                <TabItem Header="Настройки">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
                        <StackPanel>
                            <DockPanel Margin="2,0,0,16">
                                <Button DockPanel.Dock="Right" Style="{StaticResource GhostButton}" VerticalAlignment="Center"
                                        Command="{Binding OpenLinkCommand}"
                                        CommandParameter="https://github.com/Asterlike/zapret2UI/blob/main/manual_zapret2UI.md#14-настройки--полный-список"
                                        ToolTip="Открыть раздел «Настройки — полный список» в инструкции">
                                    <emoji:TextBlock Text="📖  Инструкция"/>
                                </Button>
                                <TextBlock Text="Настройки" Style="{StaticResource H1}" VerticalAlignment="Center"/>
                            </DockPanel>

                            <!-- Two columns so the settings fill the width instead of a half-empty left strip. -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,8,0">

                            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="Масштаб интерфейса" Style="{StaticResource H2}" Margin="0,0,0,8"/>
                                    <TextBlock Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,12"
                                               Text="Увеличивает весь интерфейс поверх масштаба Windows — на 4K и мониторах с высоким разрешением, где всё выглядит мелко. Работает независимо от системного DPI, применяется сразу."/>
                                    <StackPanel Orientation="Horizontal">
                                        <RadioButton Style="{StaticResource ChipButton}" Content="100%" IsChecked="{Binding Scale100, Mode=TwoWay}"/>
                                        <RadioButton Style="{StaticResource ChipButton}" Content="125%" IsChecked="{Binding Scale125, Mode=TwoWay}"/>
                                        <RadioButton Style="{StaticResource ChipButton}" Content="150%" IsChecked="{Binding Scale150, Mode=TwoWay}"/>
                                        <RadioButton Style="{StaticResource ChipButton}" Content="175%" IsChecked="{Binding Scale175, Mode=TwoWay}"/>
                                        <RadioButton Style="{StaticResource ChipButton}" Content="200%" IsChecked="{Binding Scale200, Mode=TwoWay}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="Движок" Style="{StaticResource H2}" Margin="0,0,0,12"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <TextBlock Text="Установленная версия:" Style="{StaticResource Muted}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding EngineVersion}" Margin="8,0,0,0" VerticalAlignment="Center"
                                                   FontWeight="SemiBold"/>
                                        <Button Content="Проверить обновления" Command="{Binding CheckUpdateCommand}"
                                                Style="{StaticResource GhostButton}" Margin="16,0,0,0"/>
                                    </StackPanel>
                                    <CheckBox Content="Автоматически обновлять движок при запуске"
                                              IsChecked="{Binding AutoUpdateEngine}" Style="{StaticResource ToggleSwitch}"
                                              Margin="0,4"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="Запуск" Style="{StaticResource H2}" Margin="0,0,0,12"/>
                                    <CheckBox Content="Запускать Zapret2UI при входе в Windows"
                                              IsChecked="{Binding AutostartEnabled}" Style="{StaticResource ToggleSwitch}"
                                              Margin="0,6"/>
                                    <CheckBox Content="Сразу запускать обход при старте приложения"
                                              IsChecked="{Binding AutostartEngine}" Style="{StaticResource ToggleSwitch}"
                                              Margin="0,6"/>
                                    <CheckBox Content="Сворачивать в трей вместо закрытия"
                                              IsChecked="{Binding MinimizeToTray}" Style="{StaticResource ToggleSwitch}"
                                              Margin="0,6"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource Card}" Margin="0,16,0,0">
                                <StackPanel>
                                    <TextBlock Text="Уведомления" Style="{StaticResource H2}" Margin="0,0,0,8"/>
                                    <TextBlock Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,10"
                                               Text="Небольшие подсказки в углу экрана (запуск, остановка, авто-починка) — видны, даже когда приложение свёрнуто в трей."/>
                                    <CheckBox Content="Показывать уведомления"
                                              IsChecked="{Binding NotificationsEnabled}" Style="{StaticResource ToggleSwitch}"
                                              Margin="0,6"/>
                                    <CheckBox Content="Звук уведомлений"
                                              IsChecked="{Binding NotificationSound}" Style="{StaticResource ToggleSwitch}"
                                              Margin="0,6"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource Card}" Margin="0,16,0,0">
                                <StackPanel>
                                    <TextBlock Text="Авто-починка" Style="{StaticResource H2}" Margin="0,0,0,8"/>
                                    <TextBlock Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,10"
                                               Text="Приложение фоном следит за доступностью Discord и YouTube. Если обход вдруг перестал работать — само переподбирает рабочую стратегию и перезапускает, без вашего участия."/>
                                    <CheckBox Content="Сам переподбирать обход, если он сломался"
                                              IsChecked="{Binding AutoHeal}" Style="{StaticResource ToggleSwitch}"
                                              Margin="0,4"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource Card}" Margin="0,16,0,0">
                                <StackPanel>
                                    <TextBlock Text="Область обхода" Style="{StaticResource H2}" Margin="0,0,0,8"/>
                                    <TextBlock Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,10"
                                               Text="Обычно обходятся только YouTube, Discord, Telegram и ваши «Свои цели»/хостлисты — остальное не трогается, игры и приложения работают как есть. Включите, чтобы обходить любой заблокированный сайт (весь TLS/QUIC, кроме списка исключений) — удобно, но может сломать приложение, которого нет в исключениях. Меняется на лету."/>
                                    <CheckBox Content="Обходить все сайты, а не только из списков"
                                              IsChecked="{Binding BypassAllSites}" Style="{StaticResource ToggleSwitch}"
                                              Margin="0,4"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource Card}" Margin="0,16,0,0">
                                <StackPanel>
                                    <TextBlock Text="Игровой фильтр" Style="{StaticResource H2}" Margin="0,0,0,8"/>
                                    <TextBlock Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,10"
                                               Text="По умолчанию ВЫКЛ — обход не трогает игровой трафик (высокие порты), игры работают напрямую. Включите, только если душат саму игру: обход распространится на все порты выше 1023 (заодно покроет Discord-медиа на высоких портах). Меняется на лету — движок перезапустится."/>
                                    <CheckBox Content="Распространять обход на игровые порты (>1023)"
                                              IsChecked="{Binding GameFilter}" Style="{StaticResource ToggleSwitch}"
                                              Margin="0,4"/>
                                </StackPanel>
                            </Border>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="8,0,0,0">

                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="QUIC / HTTP-3" Style="{StaticResource H2}" Margin="0,0,0,8"/>
                                    <TextBlock Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,10"
                                               Text="Провайдер/ТСПУ часто режет именно QUIC (HTTP-3) — тогда YouTube «тормозит», а Discord не грузит медиа, хотя по TCP всё открывается. Включите, чтобы принудительно отправить YouTube/Discord на TCP: QUIC-подключения отбрасываются, браузер сам откатывается на HTTP/2. Меняется на лету — движок перезапустится."/>
                                    <CheckBox Content="Отключить QUIC (форсировать TCP)"
                                              IsChecked="{Binding DisableQuic}" Style="{StaticResource ToggleSwitch}"
                                              Margin="0,4"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource Card}" Margin="0,16,0,0">
                                <StackPanel>
                                    <TextBlock Text="Telegram-прокси через движок" Style="{StaticResource H2}" Margin="0,0,0,8"/>
                                    <TextBlock Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,10"
                                               Text="Если встроенный прокси Telegram подключается, но связь всё равно рвётся (мобильный DPI/ТСПУ портит туннель на лету), включите — движок обхода дополнительно прикроет 443-соединения прокси, и стратегия будет собираться уже с этим профилем. Нужно, чтобы обход был запущен. Большинству не требуется — по умолчанию выключено. Меняется на лету."/>
                                    <CheckBox Content="Прикрывать соединения Telegram-прокси движком"
                                              IsChecked="{Binding TgProxyCoverage}" Style="{StaticResource ToggleSwitch}"
                                              Margin="0,4"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource Card}" Margin="0,16,0,0">
                                <StackPanel>
                                    <TextBlock Text="Обход по IP (для жёстких блоков)" Style="{StaticResource H2}" Margin="0,0,0,8"/>
                                    <TextBlock Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,10"
                                               Text="Если Discord режут по IP-адресам, обход по доменам не помогает. Соберите актуальные подсети Discord (резолв доменов) — список сохранится в ipset-discord.txt, его можно подключить в своём пресете через токен {IPSET}."/>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Собрать IP-список Discord" Command="{Binding BuildDiscordIpsetCommand}"
                                                Style="{StaticResource GhostButton}"
                                                Visibility="{Binding IsBuildingIpset, Converter={StaticResource BoolToVis}, ConverterParameter=invert}"/>
                                        <TextBlock Text="Сбор…" Style="{StaticResource Muted}" VerticalAlignment="Center"
                                                   Visibility="{Binding IsBuildingIpset, Converter={StaticResource BoolToVis}}"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding IpsetStatus}" Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,10,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource Card}" Margin="0,16,0,0">
                                <StackPanel>
                                    <TextBlock Text="Исключения (антивирус и брандмауэр)" Style="{StaticResource H2}" Margin="0,0,0,8"/>
                                    <TextBlock Text="{Binding ExclusionsStatus}" Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,10"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Добавить в исключения" Command="{Binding ApplyExclusionsCommand}"
                                                Style="{StaticResource GhostButton}"
                                                Visibility="{Binding IsApplyingExclusions, Converter={StaticResource BoolToVis}, ConverterParameter=invert}"/>
                                        <TextBlock Text="Добавление…" Style="{StaticResource Muted}" VerticalAlignment="Center"
                                                   Visibility="{Binding IsApplyingExclusions, Converter={StaticResource BoolToVis}}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource Card}" Margin="0,16,0,0">
                                <StackPanel>
                                    <TextBlock Text="Проверка окружения" Style="{StaticResource H2}" Margin="0,0,0,8"/>
                                    <TextBlock Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,10"
                                               Text="Ищет в системе то, что мешает обходу: другие программы обхода блокировок (они занимают тот же драйвер WinDivert), включённый VPN или туннельный адаптер, а также недокачанный движок. По каждой находке показывает, что это значит и что сделать. Та же проверка идёт автоматически при запуске — здесь её можно вызвать в любой момент."/>
                                    <Button Content="Проверить окружение" Click="OnCheckEnvironment"
                                            Style="{StaticResource GhostButton}" HorizontalAlignment="Left"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource Card}" Margin="0,16,0,0">
                                <StackPanel>
                                    <TextBlock Text="Вводная для новичка" Style="{StaticResource H2}" Margin="0,0,0,8"/>
                                    <TextBlock Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,10"
                                               Text="Разбор по шагам: что нажать, чего ждать и что делать, если не заработало. Показывается один раз при первом запуске — отсюда её можно открыть снова в любой момент."/>
                                    <Button Content="Показать вводную" Command="{Binding OpenWelcomeCommand}"
                                            Style="{StaticResource GhostButton}" HorizontalAlignment="Left"/>
                                </StackPanel>
                            </Border>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>

            <!-- ============ Modal: how it works / app tour ============ -->
            <Grid Grid.Row="0" Grid.RowSpan="2" Panel.ZIndex="100" Background="#C0000000"
                  Visibility="{Binding ShowHowItWorks, Converter={StaticResource BoolToVis}}">
                <Border Style="{StaticResource ModalCard}" MaxWidth="520" MaxHeight="640"
                        VerticalAlignment="Center" HorizontalAlignment="Center"
                        BorderBrush="{StaticResource AccentBrush}" BorderThickness="1">
                    <Border.RenderTransform><ScaleTransform/></Border.RenderTransform>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Grid>
                                <TextBlock Text="Как это работает" Style="{StaticResource H2}"/>
                                <Button Content="✕" Command="{Binding CloseHowItWorksCommand}"
                                        Style="{StaticResource GhostButton}" HorizontalAlignment="Right"
                                        VerticalAlignment="Top" Padding="9,2" MinWidth="0"/>
                            </Grid>

                            <TextBlock Style="{StaticResource Muted}" FontSize="12.5" TextWrapping="Wrap" Margin="0,8,0,0"
                                       Text="Zapret2UI обходит блокировки и замедления (DPI) для Discord, YouTube и Telegram. Внутри работает движок winws2 — он на лету «ломает» распознавание трафика провайдером, не меняя сами сайты. Для работы нужны права администратора (запрашиваются при старте)."/>

                            <!-- 1. Быстрый старт -->
                            <TextBlock Text="1. С чего начать" FontWeight="Bold" Margin="0,16,0,4"
                                       FontFamily="{StaticResource DisplayFont}"/>
                            <TextBlock Style="{StaticResource Muted}" FontSize="12.5" TextWrapping="Wrap"
                                       Text="На вкладке «Главная» нажмите большую кнопку «Включить обход» — приложение применит рекомендуемую стратегию и запустит обход. Сверху можно выбрать цель (Discord + YouTube / только Discord / только YouTube). Если не помогло — «Подобрать стратегию» переберёт проверенные варианты под вашу сеть; начинать стоит с неё. «Сгенерировать стратегию» собирает вариант с нуля — дольше, но помогает там, где подбор не пробил."/>

                            <!-- 2. Простой / Расширенный -->
                            <TextBlock Text="2. Два режима" FontWeight="Bold" Margin="0,14,0,4"
                                       FontFamily="{StaticResource DisplayFont}"/>
                            <TextBlock Style="{StaticResource Muted}" FontSize="12.5" TextWrapping="Wrap"
                                       Text="Переключатель «Простой / Расширенный» вверху по центру. В простом режиме — только «Главная»: кнопка вкл/выкл, выбор цели, «Подобрать»/«Сгенерировать» стратегию, тумблер Telegram и карточка подключения. В расширенном открываются вкладки сверху: Главная, Стратегии, Хостлисты, Диагностика, Журнал, Telegram, Настройки."/>

                            <!-- 3. Вкладки -->
                            <TextBlock Text="3. Что где находится" FontWeight="Bold" Margin="0,14,0,6"
                                       FontFamily="{StaticResource DisplayFont}"/>
                            <StackPanel>
                                <TextBlock Style="{StaticResource Muted}" FontSize="12.5" TextWrapping="Wrap" Text="• Главная — статус, большая кнопка вкл/выкл, выбор цели, кнопки «Подобрать» и «Сгенерировать» стратегию."/>
                                <TextBlock Style="{StaticResource Muted}" FontSize="12.5" TextWrapping="Wrap" Margin="0,3,0,0" Text="• Стратегии — готовые стратегии по группам (Основные, Личные/Сгенерированные). Справа — описание, подключённые хостлисты и «терминал» аргументов winws2. Кнопки: Применить, Дублировать (чтобы править копию), Сохранить, Удалить."/>
                                <TextBlock Style="{StaticResource Muted}" FontSize="12.5" TextWrapping="Wrap" Margin="0,3,0,0" Text="• Хостлисты — списки доменов, к которым применяется обход (один домен = одна строка)."/>
                                <TextBlock Style="{StaticResource Muted}" FontSize="12.5" TextWrapping="Wrap" Margin="0,3,0,0" Text="• Диагностика — подбор/генерация стратегии и матрица доступности сервисов (см. ниже)."/>
                                <TextBlock Style="{StaticResource Muted}" FontSize="12.5" TextWrapping="Wrap" Margin="0,3,0,0" Text="• Журнал — живой вывод движка (для диагностики проблем)."/>
                                <TextBlock Style="{StaticResource Muted}" FontSize="12.5" TextWrapping="Wrap" Margin="0,3,0,0" Text="• Telegram — встроенный прокси: включение, адрес/секрет, порт и краткое руководство."/>
                                <TextBlock Style="{StaticResource Muted}" FontSize="12.5" TextWrapping="Wrap" Margin="0,3,0,0" Text="• Настройки — обновление движка, автозапуск, авто-починка, QUIC, игровой фильтр, обход по IP, исключения (антивирус/брандмауэр)."/>
                            </StackPanel>

                            <!-- 4. Диагностика -->
                            <TextBlock Text="4. Диагностика, подбор и генерация" FontWeight="Bold" Margin="0,14,0,4"
                                       FontFamily="{StaticResource DisplayFont}"/>
                            <StackPanel>
                                <TextBlock Style="{StaticResource Muted}" FontSize="12.5" TextWrapping="Wrap" Text="• «Подобрать лучшую» — быстро: перебирает готовые стратегии и оставляет одну, общую для всех сервисов. Если Discord и YouTube требуют РАЗНЫХ обходов, одной общей может не хватить — тогда используйте «Сгенерировать»."/>
                                <TextBlock Style="{StaticResource Muted}" FontSize="12.5" TextWrapping="Wrap" Margin="0,3,0,0" Text="• «Сгенерировать стратегию» — собирает персональную стратегию под «всё сразу»: подбирает лучший обход отдельно для Discord и для YouTube, затем объединяет их в одну стратегию и проверяет её целиком — чтобы сервисы работали вместе, а не только по отдельности. Медленнее, но именно это даёт рабочую стратегию под всё."/>
                                <TextBlock Style="{StaticResource Muted}" FontSize="12.5" TextWrapping="Wrap" Margin="0,3,0,0" Text="• «Диагностика» — просто показывает текущую доступность (HTTP / TLS 1.2 / TLS 1.3 / пинг) по сервисам, без подбора. По упавшей ячейке видно, что именно режет провайдер."/>
                                <TextBlock Style="{StaticResource Muted}" FontSize="12.5" TextWrapping="Wrap" Margin="0,3,0,0" Text="• После подбора/генерации список «Успешные стратегии» позволяет сохранить любые рабочие варианты в пресеты (не только лучший)."/>
                                <TextBlock Style="{StaticResource Muted}" FontSize="12.5" TextWrapping="Wrap" Margin="0,3,0,0" Text="• «Свои цели» — добавьте свой сайт: приложение найдёт его поддомены и домены того же бренда в других зонах (yandex.ru → yandex.kz/md…), будет проверять их в диагностике, учитывать при подборе/генерации и применять к ним обход."/>
                            </StackPanel>

                            <!-- 5. Настройки -->
                            <TextBlock Text="5. Полезное в Настройках" FontWeight="Bold" Margin="0,14,0,4"
                                       FontFamily="{StaticResource DisplayFont}"/>
                            <StackPanel>
                                <TextBlock Style="{StaticResource Muted}" FontSize="12.5" TextWrapping="Wrap" Text="• Авто-починка — фоном следит за Discord и YouTube; если обход сломался, сам переподбирает рабочую стратегию."/>
                                <TextBlock Style="{StaticResource Muted}" FontSize="12.5" TextWrapping="Wrap" Margin="0,3,0,0" Text="• Игровой фильтр — по умолчанию ВЫКЛ, обход не трогает игровой трафик. Включайте, только если душат саму игру."/>
                                <TextBlock Style="{StaticResource Muted}" FontSize="12.5" TextWrapping="Wrap" Margin="0,3,0,0" Text="• Обход по IP — если ресурс режут по адресам, а не доменам: соберите подсети Discord (резолв доменов), список подключается через токен {IPSET}."/>
                                <TextBlock Style="{StaticResource Muted}" FontSize="12.5" TextWrapping="Wrap" Margin="0,3,0,0" Text="• Движок и приложение обновляются с GitHub; если api недоступен у провайдера — проверка идёт и через обычный github.com."/>
                            </StackPanel>

                            <!-- 6. Telegram (встроенный прокси) -->
                            <TextBlock Text="6. Telegram — встроенный прокси" FontWeight="Bold" Margin="0,14,0,4"
                                       FontFamily="{StaticResource DisplayFont}"/>
                            <TextBlock Style="{StaticResource Muted}" FontSize="12.5" TextWrapping="Wrap"
                                       Text="Telegram в РФ часто режут по IP дата-центров — обычный десинк тут не помогает. Поэтому в приложении есть свой локальный MTProto-прокси (карточка «Telegram» на «Главной»): он проводит трафик Telegram через WebSocket к серверам, до которых блокировка не дотягивается. Нажмите «Включить для Telegram», затем «Открыть в Telegram» — прокси пропишется в настройках автоматически (или введите адрес 127.0.0.1 и порт вручную). Свой сторонний MTProxy больше не нужен."/>

                            <!-- 7. Если не работает -->
                            <TextBlock Text="7. Если не работает" FontWeight="Bold" Margin="0,14,0,4"
                                       FontFamily="{StaticResource DisplayFont}"/>
                            <TextBlock Style="{StaticResource Muted}" FontSize="12.5" TextWrapping="Wrap"
                                       Text="Стратегии зависят от оператора связи — одна и та же не работает у всех одинаково. Порядок действий: попробуйте другой пресет из списка → «Подобрать лучшую» → «Сгенерировать стратегию». Если совсем ничего не пробивает — это, скорее всего, сторона регулятора. Для Telegram используйте встроенный прокси (пункт 6)."/>

                            <!-- 8. Документация -->
                            <TextBlock Text="8. Документация и ссылки" FontWeight="Bold" Margin="0,14,0,4"
                                       FontFamily="{StaticResource DisplayFont}"/>
                            <TextBlock Style="{StaticResource Muted}" FontSize="12.5" TextWrapping="Wrap" Margin="0,0,0,8"
                                       Text="Полное руководство, обзор возможностей и ответы на частые вопросы — на GitHub. Новости и обсуждение — в Telegram-канале."/>
                            <WrapPanel>
                                <Button Style="{StaticResource GhostButton}" Margin="0,0,8,8"
                                        Command="{Binding OpenLinkCommand}"
                                        CommandParameter="https://github.com/Asterlike/zapret2UI/blob/main/manual_zapret2UI.md">
                                    <emoji:TextBlock Text="📖  Полная инструкция"/>
                                </Button>
                                <Button Style="{StaticResource GhostButton}" Margin="0,0,8,8"
                                        Command="{Binding OpenLinkCommand}"
                                        CommandParameter="https://github.com/Asterlike/zapret2UI/blob/main/README.md">
                                    <emoji:TextBlock Text="📄  О программе (README)"/>
                                </Button>
                                <Button Style="{StaticResource GhostButton}" Margin="0,0,8,8"
                                        Command="{Binding OpenLinkCommand}"
                                        CommandParameter="https://t.me/Zapret2UI">
                                    <emoji:TextBlock Text="✈  Telegram-канал"/>
                                </Button>
                            </WrapPanel>

                            <Button Content="Понятно" Command="{Binding CloseHowItWorksCommand}"
                                    Style="{StaticResource StartStopButton}" HorizontalAlignment="Right" Margin="0,18,0,0"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- ============ Modal: first-run walkthrough ============
                 Shown once on a fresh install (MainWindow.OnLoaded, suppressed under the screenshot
                 harness) and on demand from Настройки → «Показать вводную». Deliberately a short
                 ordered path — what to press, what to expect, what to do when it doesn't work —
                 handing off to the full "Как это работает" reference for the details. -->
            <Grid Grid.Row="0" Grid.RowSpan="2" Panel.ZIndex="99" Background="#C0000000"
                  Visibility="{Binding ShowWelcome, Converter={StaticResource BoolToVis}}">
                <Border Style="{StaticResource ModalCard}" MaxWidth="560" MaxHeight="660"
                        VerticalAlignment="Center" HorizontalAlignment="Center"
                        BorderBrush="{StaticResource AccentBrush}" BorderThickness="1">
                    <Border.RenderTransform><ScaleTransform/></Border.RenderTransform>
                    <!-- Buttons live OUTSIDE the ScrollViewer: this modal has no ✕, so if the actions
                         scrolled off the bottom a first-time user would have no way out of it. -->
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Добро пожаловать" Style="{StaticResource H2}"/>
                            <TextBlock Style="{StaticResource Muted}" FontSize="12.5" TextWrapping="Wrap" Margin="0,8,0,0"
                                       Text="Zapret2UI возвращает доступ к Discord, YouTube и Telegram. Это не VPN: трафик никуда не перенаправляется и не шифруется заново — движок winws2 лишь мешает провайдеру опознать, куда вы идёте. Поэтому скорость не падает, а всё, чего нет в списках — игры, банки, рабочие сервисы — не затрагивается вообще."/>

                            <TextBlock Text="1. Включите обход" FontWeight="Bold" Margin="0,16,0,4"
                                       FontFamily="{StaticResource DisplayFont}"/>
                            <TextBlock Style="{StaticResource Muted}" FontSize="12.5" TextWrapping="Wrap"
                                       Text="На «Главной» нажмите большую кнопку «Включить обход» — приложение возьмёт рекомендуемую стратегию и запустит движок. Windows спросит права администратора: они нужны драйверу, который перехватывает пакеты, без них обход работать не может. Окно можно закрыть — программа свернётся в трей и продолжит работать."/>

                            <TextBlock Text="2. Проверьте, что получилось" FontWeight="Bold" Margin="0,14,0,4"
                                       FontFamily="{StaticResource DisplayFont}"/>
                            <TextBlock Style="{StaticResource Muted}" FontSize="12.5" TextWrapping="Wrap"
                                       Text="Откройте Discord или YouTube. Заработало — больше делать нечего. Не заработало — это не поломка приложения: провайдеры фильтруют по-разному, и одна стратегия физически не может подойти всем. Просто переходите к шагу 3."/>

                            <TextBlock Text="3. Не пробило — подберите стратегию" FontWeight="Bold" Margin="0,14,0,4"
                                       FontFamily="{StaticResource DisplayFont}"/>
                            <TextBlock Style="{StaticResource Muted}" FontSize="12.5" TextWrapping="Wrap"
                                       Text="«Подобрать стратегию» переберёт проверенные варианты и оставит тот, что открывает ваши сервисы — обычно минута-две. Начинать стоит именно с неё: она идёт по готовому списку и потому предсказуемее. Если подбор не помог — «Сгенерировать стратегию»: она собирает вариант с нуля, отдельно под Discord и под YouTube. Дольше, но берёт там, где подбор пасует."/>

                            <TextBlock Text="4. Telegram — отдельная история" FontWeight="Bold" Margin="0,14,0,4"
                                       FontFamily="{StaticResource DisplayFont}"/>
                            <TextBlock Style="{StaticResource Muted}" FontSize="12.5" TextWrapping="Wrap"
                                       Text="Telegram блокируют по адресам дата-центров, и обход DPI тут бессилен — поэтому для него внутри есть свой прокси. Включите тумблер «Telegram» на «Главной» и нажмите «Открыть в Telegram»: настройки пропишутся сами. Прав администратора он не требует, от основного обхода не зависит и может быть включён всегда."/>

                            <TextBlock Text="5. Если ничего не помогло" FontWeight="Bold" Margin="0,14,0,4"
                                       FontFamily="{StaticResource DisplayFont}"/>
                            <TextBlock Style="{StaticResource Muted}" FontSize="12.5" TextWrapping="Wrap"
                                       Text="«Настройки» → «Проверить окружение» покажет, не мешает ли включённый VPN или другая программа обхода: они занимают тот же драйвер, и вместе с ними обход не заработает. Вкладка «Диагностика» покажет, что именно режет провайдер, а «Журнал» — что делает движок."/>
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                        <Button Content="Как это работает" Command="{Binding WelcomeToHowItWorksCommand}"
                                Style="{StaticResource GhostButton}" Margin="0,0,8,0"/>
                        <!-- MinWidth keeps the button from resizing as the countdown digits drop off. -->
                        <Button Content="{Binding WelcomeButtonText}" Command="{Binding CloseWelcomeCommand}"
                                Style="{StaticResource PrimaryButton}" MinWidth="176"/>
                    </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- ============ Modal: add / edit a custom target ============ -->
            <Grid Grid.Row="0" Grid.RowSpan="2" Panel.ZIndex="100" Background="#C0000000"
                  Visibility="{Binding ShowTargetPopup, Converter={StaticResource BoolToVis}}">
                <Border Style="{StaticResource ModalCard}" MaxWidth="500" MaxHeight="660"
                        VerticalAlignment="Center" HorizontalAlignment="Center"
                        BorderBrush="{StaticResource AccentBrush}" BorderThickness="1">
                    <Border.RenderTransform><ScaleTransform/></Border.RenderTransform>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <TextBlock>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource H2}">
                                        <Setter Property="Text" Value="Своя цель"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding TargetIsNew}" Value="True">
                                                <Setter Property="Text" Value="Новая цель"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <Button Content="✕" Command="{Binding CloseTargetPopupCommand}"
                                    Style="{StaticResource GhostButton}" HorizontalAlignment="Right"
                                    VerticalAlignment="Top" Padding="9,2" MinWidth="0"/>
                        </Grid>

                        <TextBlock Grid.Row="1" Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,6,0,0"
                                   Text="Укажите корневой домен сайта (например yandex.ru). По кнопке приложение найдёт его поддомены (crt.sh) и домены того же бренда на других зонах, проверив по TLS-сертификату, что они реально принадлежат тому же сервису (yandex.kz, yandex.md…), а не сквоттерам с похожим именем. Проверьте список, добавьте/уберите свои и сохраните."/>

                        <Grid Grid.Row="2" Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Margin="0,0,8,0"
                                     Text="{Binding TargetRootInput, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="1" Command="{Binding ExpandTargetCommand}"
                                    Style="{StaticResource GhostButton}">
                                <TextBlock>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Найти домены"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsExpandingTarget}" Value="True">
                                                    <Setter Property="Text" Value="Ищу…"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Button>
                        </Grid>

                        <TextBlock Grid.Row="3" Text="Домены цели (по одному в строке)"
                                   Style="{StaticResource Muted}" FontSize="11" Margin="0,12,0,6"/>
                        <TextBox Grid.Row="4" MinHeight="160"
                                 Text="{Binding TargetDomainsText, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True" TextWrapping="NoWrap" Background="{StaticResource BgBrush}"
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                 FontFamily="{StaticResource MonoFont}" FontSize="12.5"/>

                        <StackPanel Grid.Row="5" Margin="0,10,0,0">
                            <!-- animated "busy" bar while domains are being verified — so it's visibly working -->
                            <ProgressBar Style="{StaticResource BusyBar}" Margin="0,0,0,8"
                                         Visibility="{Binding IsExpandingTarget, Converter={StaticResource BoolToVis}}"/>
                            <TextBlock Text="{Binding TargetStatus}" Style="{StaticResource Muted}"
                                       FontSize="11.5" TextWrapping="Wrap"/>
                        </StackPanel>

                        <StackPanel Grid.Row="6" Orientation="Horizontal" Margin="0,14,0,0">
                            <Button Content="Сохранить цель" Command="{Binding SaveTargetCommand}"
                                    Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"/>
                            <Button Content="Закрыть" Command="{Binding CloseTargetPopupCommand}"
                                    Style="{StaticResource GhostButton}"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
