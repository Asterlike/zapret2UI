<Window x:Class="ZapretUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Zapret UI" Height="690" Width="1020" MinHeight="580" MinWidth="880"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" ResizeMode="CanResize"
        Icon="Assets/app.ico"
        Background="{StaticResource BgBrush}"
        FontFamily="{StaticResource UiFont}">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="40" ResizeBorderThickness="6"
                            CornerRadius="0" GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border x:Name="RootBorder" BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ============ Caption bar ============ -->
            <Grid Grid.Row="0" Background="{StaticResource BgBrush}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                    <Image Source="/Assets/app.ico" Width="18" Height="18" Margin="0,0,9,0"/>
                    <TextBlock Text="Zapret UI" FontWeight="SemiBold" FontSize="13"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="DPI bypass" FontSize="11" Foreground="{StaticResource FgMutedBrush}"
                               VerticalAlignment="Center" Margin="10,1,0,0"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button x:Name="MinButton" Style="{StaticResource CaptionButton}" Click="OnMinimize">
                        <TextBlock Text="&#xE921;" FontFamily="{StaticResource IconFont}" FontSize="11"/>
                    </Button>
                    <Button x:Name="MaxButton" Style="{StaticResource CaptionButton}" Click="OnMaximizeRestore">
                        <TextBlock Text="&#xE922;" FontFamily="{StaticResource IconFont}" FontSize="11"/>
                    </Button>
                    <Button x:Name="CloseButton" Style="{StaticResource CloseButton}" Click="OnCloseClick">
                        <TextBlock Text="&#xE8BB;" FontFamily="{StaticResource IconFont}" FontSize="11"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- ============ Header ============ -->
            <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush2}" BorderThickness="0,1,0,1" Padding="22,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="11" Height="11" Margin="0,0,10,0"
                                 Fill="{Binding State, Converter={StaticResource StateToBrush}}">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard Name="Pulse">
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                            From="1" To="0.25" Duration="0:0:0.9"
                                                            AutoReverse="True" RepeatBehavior="Forever"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <StopStoryboard BeginStoryboardName="Pulse"/>
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding State, Converter={StaticResource StateToText}}"
                                       FontSize="15" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding SelectedPreset.Name, FallbackValue='пресет не выбран'}"
                                       FontSize="11.5" Foreground="{StaticResource FgMutedBrush}"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="28,0">
                        <TextBlock Text="{Binding UpdateStatus}" Style="{StaticResource Muted}"
                                   TextTrimming="CharacterEllipsis"/>
                        <ProgressBar Value="{Binding UpdateProgress, Mode=OneWay}" Maximum="1" Margin="0,6,0,0"
                                     Visibility="{Binding IsUpdating, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>

                    <Button Grid.Column="2" Command="{Binding ToggleCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource StartStopButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock>
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="&#x25B6;  Запустить"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                            <Setter Property="Text" Value="&#x25A0;  Остановить"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Button>
                </Grid>
            </Border>

            <!-- ============ Body ============ -->
            <TabControl x:Name="MainTabs" Grid.Row="2" Style="{StaticResource SidebarTabs}">
                <TabControl.Resources>
                    <Style TargetType="TabItem" BasedOn="{StaticResource SidebarTabItem}"/>
                </TabControl.Resources>

                <!-- Управление -->
                <TabItem Header="Управление" Tag="&#xE7E8;">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
                        <StackPanel MaxWidth="740" HorizontalAlignment="Left">
                            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="Активный пресет" Style="{StaticResource Muted}"/>
                                    <TextBlock Text="{Binding SelectedPreset.Name, FallbackValue='—'}"
                                               Style="{StaticResource H2}" Margin="0,4,0,8"/>
                                    <TextBlock Text="{Binding SelectedPreset.Description}" Style="{StaticResource Muted}"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,14,0,0"
                                                Visibility="{Binding SelectedPreset.UsesHostlist, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="Хостлист:" Style="{StaticResource Muted}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding SelectedHostlist, FallbackValue='не выбран'}"
                                                   Margin="8,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="Командная строка движка" Style="{StaticResource Muted}"/>
                                    <Border Background="{StaticResource BgBrush}" CornerRadius="8" Padding="12"
                                            Margin="0,8,0,0" BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1">
                                        <TextBlock Text="{Binding CommandPreview}" FontFamily="{StaticResource MonoFont}"
                                                   FontSize="12" Foreground="{StaticResource FgMutedBrush}"
                                                   TextWrapping="Wrap"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- Пресеты -->
                <TabItem Header="Пресеты" Tag="&#xE71D;">
                    <Grid Margin="24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="280"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource Card}" Padding="8" Margin="0,0,16,0">
                            <ListBox ItemsSource="{Binding Presets}" SelectedItem="{Binding SelectedPreset}"
                                     ItemContainerStyle="{StaticResource SelectableItem}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Description}" Style="{StaticResource Muted}"
                                                       FontSize="11.5" TextTrimming="CharacterEllipsis" MaxHeight="32"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource Card}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="{Binding SelectedPreset.Name, FallbackValue='Выберите пресет'}"
                                           Style="{StaticResource H2}"/>
                                <TextBlock Grid.Row="1" Text="{Binding SelectedPreset.Description}"
                                           Style="{StaticResource Muted}" Margin="0,6,0,12"/>

                                <Grid Grid.Row="2">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Text="Аргументы winws2 (по одному в строке)"
                                               Style="{StaticResource Muted}" Margin="0,0,0,6"/>
                                    <TextBox Grid.Row="1" Text="{Binding PresetArgsText, UpdateSourceTrigger=PropertyChanged}"
                                             IsReadOnly="{Binding SelectedPresetEditable, Converter={StaticResource InverseBool}}"
                                             AcceptsReturn="True" TextWrapping="NoWrap"
                                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                             FontFamily="{StaticResource MonoFont}" FontSize="12"/>
                                </Grid>

                                <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,14,0,0">
                                    <Button Content="Дублировать" Command="{Binding DuplicatePresetCommand}"
                                            Style="{StaticResource GhostButton}" Margin="0,0,8,0"/>
                                    <Button Content="Сохранить" Command="{Binding SavePresetCommand}"
                                            Style="{StaticResource GhostButton}" Margin="0,0,8,0"/>
                                    <Button Content="Удалить" Command="{Binding DeletePresetCommand}"
                                            Style="{StaticResource GhostButton}"/>
                                    <TextBlock Text="Встроенный — дублируйте для правки"
                                               Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="14,0,0,0"
                                               Visibility="{Binding SelectedPresetEditable, Converter={StaticResource BoolToVis}, ConverterParameter=invert}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- Хостлисты -->
                <TabItem Header="Хостлисты" Tag="&#xE8FD;">
                    <Grid Margin="24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="240"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource Card}" Padding="8" Margin="0,0,16,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <ListBox Grid.Row="0" ItemsSource="{Binding Hostlists}"
                                         SelectedItem="{Binding SelectedHostlist}"
                                         ItemContainerStyle="{StaticResource SelectableItem}"/>
                                <Button Grid.Row="1" Content="+ Новый список" Command="{Binding NewHostlistCommand}"
                                        Style="{StaticResource GhostButton}" Margin="4,8,4,4"/>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource Card}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="{Binding SelectedHostlist, FallbackValue='Выберите или создайте список'}"
                                           Style="{StaticResource H2}"/>

                                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,12">
                                    <TextBox Width="300" Text="{Binding NewDomain, UpdateSourceTrigger=PropertyChanged}"/>
                                    <Button Content="Добавить домен" Command="{Binding AddDomainCommand}"
                                            Style="{StaticResource GhostButton}" Margin="8,0,0,0"/>
                                </StackPanel>

                                <TextBox Grid.Row="2" Text="{Binding HostlistContent, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True" TextWrapping="NoWrap"
                                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                         FontFamily="{StaticResource MonoFont}" FontSize="12.5"/>

                                <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,14,0,0">
                                    <Button Content="Сохранить список" Command="{Binding SaveHostlistCommand}"
                                            Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"/>
                                    <Button Content="Удалить список" Command="{Binding DeleteHostlistCommand}"
                                            Style="{StaticResource GhostButton}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- Проверка стратегий -->
                <TabItem Header="Проверка" Tag="&#xE721;">
                    <Grid Margin="24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Авто-подбор рабочей стратегии (blockcheck)" Style="{StaticResource H2}"/>
                                <TextBlock Style="{StaticResource Muted}" Margin="0,6,0,14"
                                           Text="Укажите заблокированный сайт. Приложение по очереди пробует стратегии и показывает, какие пробивают именно у вашего провайдера. Рабочую можно сохранить как пресет."/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Text="{Binding TestDomain, UpdateSourceTrigger=PropertyChanged}"
                                             VerticalContentAlignment="Center"/>
                                    <Button Grid.Column="1" Content="Проверить" Command="{Binding RunTestCommand}"
                                            Style="{StaticResource PrimaryButton}" Margin="10,0,0,0"
                                            Visibility="{Binding IsTesting, Converter={StaticResource BoolToVis}, ConverterParameter=invert}"/>
                                    <Button Grid.Column="1" Content="Остановить" Command="{Binding StopTestCommand}"
                                            Style="{StaticResource GhostButton}" Margin="10,0,0,0"
                                            Visibility="{Binding IsTesting, Converter={StaticResource BoolToVis}}"/>
                                </Grid>

                                <ListBox ItemsSource="{Binding TestKinds}" SelectedIndex="{Binding SelectedTestKindIndex}"
                                         ItemContainerStyle="{StaticResource SelectableItem}" Margin="0,12,0,0">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                </ListBox>

                                <TextBlock Text="{Binding TestStatus}" Style="{StaticResource Muted}" Margin="0,12,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="8">
                            <ListBox ItemsSource="{Binding TestResults}" SelectedItem="{Binding SelectedResult}"
                                     ItemContainerStyle="{StaticResource SelectableItem}">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="26"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Glyph}" FontWeight="Bold" FontSize="14"
                                                       VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{StaticResource FgMutedBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Works}" Value="True">
                                                                <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding Detail}" Style="{StaticResource Muted}" FontSize="11.5"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" Text="{Binding MsText}" Style="{StaticResource Muted}"
                                                       VerticalAlignment="Center" Margin="8,0,4,0"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,14,0,0">
                            <Button Content="Применить рабочую → сохранить пресет" Command="{Binding ApplyResultCommand}"
                                    Style="{StaticResource PrimaryButton}"/>
                            <TextBlock Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="14,0,0,0"
                                       Text="Выберите строку с ✓ и нажмите, чтобы сохранить её как пресет и сделать активной."/>
                        </StackPanel>
                    </Grid>
                </TabItem>

                <!-- Логи -->
                <TabItem Header="Логи" Tag="&#xE9D9;">
                    <Grid Margin="24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="Журнал движка (--debug)" Style="{StaticResource H2}" VerticalAlignment="Center"/>
                            <Button Content="Очистить" Command="{Binding ClearLogCommand}"
                                    Style="{StaticResource GhostButton}" Margin="16,0,0,0"/>
                        </StackPanel>
                        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="6">
                            <ListBox x:Name="LogList" ItemsSource="{Binding LogLines}"
                                     VirtualizingPanel.IsVirtualizing="True"
                                     ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Padding" Value="6,1"/>
                                        <Setter Property="Foreground" Value="{StaticResource FgMutedBrush}"/>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontFamily="{StaticResource MonoFont}"
                                                   FontSize="12" TextWrapping="NoWrap"
                                                   Foreground="{StaticResource FgMutedBrush}"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- Настройки -->
                <TabItem Header="Настройки" Tag="&#xE713;">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
                        <StackPanel MaxWidth="640" HorizontalAlignment="Left">
                            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="Движок" Style="{StaticResource H2}" Margin="0,0,0,12"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <TextBlock Text="Установленная версия:" Style="{StaticResource Muted}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding EngineVersion}" Margin="8,0,0,0" VerticalAlignment="Center"
                                                   FontWeight="SemiBold"/>
                                        <Button Content="Проверить обновления" Command="{Binding CheckUpdateCommand}"
                                                Style="{StaticResource GhostButton}" Margin="16,0,0,0"/>
                                    </StackPanel>
                                    <CheckBox Content="Автоматически обновлять движок при запуске"
                                              IsChecked="{Binding AutoUpdateEngine}" Style="{StaticResource ToggleSwitch}"
                                              Margin="0,4"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="Запуск" Style="{StaticResource H2}" Margin="0,0,0,12"/>
                                    <CheckBox Content="Запускать Zapret UI при входе в Windows"
                                              IsChecked="{Binding AutostartEnabled}" Style="{StaticResource ToggleSwitch}"
                                              Margin="0,6"/>
                                    <CheckBox Content="Сразу запускать обход при старте приложения"
                                              IsChecked="{Binding AutostartEngine}" Style="{StaticResource ToggleSwitch}"
                                              Margin="0,6"/>
                                    <CheckBox Content="Сворачивать в трей вместо закрытия"
                                              IsChecked="{Binding MinimizeToTray}" Style="{StaticResource ToggleSwitch}"
                                              Margin="0,6"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
    </Border>
</Window>
