<Window x:Class="ZapretUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:ctl="clr-namespace:ZapretUI.Controls"
        xmlns:emoji="clr-namespace:Emoji.Wpf;assembly=Emoji.Wpf"
        Title="Zapret UI" Height="720" Width="1280" MinHeight="580" MinWidth="880"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" ResizeMode="CanResize"
        Icon="Assets/app.ico"
        Background="{StaticResource BgBrush}"
        FontFamily="{StaticResource UiFont}">

    <Window.Resources>
        <!-- Segmented control for Простой / Расширенный -->
        <Style x:Key="ModeSegment" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource FgMutedBrush}"/>
            <Setter Property="Padding" Value="16,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="b" CornerRadius="6" Background="Transparent"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Expand/collapse chevron toggle -->
        <Style x:Key="ChevronToggle" TargetType="ToggleButton">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{StaticResource FgMutedBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="Transparent" Padding="6">
                            <TextBlock x:Name="chev" Text="&#xE70D;" FontFamily="{StaticResource IconFont}"
                                       FontSize="11" Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="chev" Property="Text" Value="&#xE70E;"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="chev" Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="46" ResizeBorderThickness="6"
                            CornerRadius="0" GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Border x:Name="RootBorder" BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1">
        <Border.Background>
            <RadialGradientBrush GradientOrigin="0.5,-0.1" Center="0.5,-0.1" RadiusX="0.9" RadiusY="0.8">
                <GradientStop Color="#FF0F1218" Offset="0"/>
                <GradientStop Color="#FF080A0E" Offset="0.6"/>
                <GradientStop Color="#FF060709" Offset="1"/>
            </RadialGradientBrush>
        </Border.Background>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="46"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ============ Decorative background blooms (violet · concept C) ============ -->
            <Grid Grid.RowSpan="2" IsHitTestVisible="False" ClipToBounds="True">
                <Ellipse Width="1000" Height="680" HorizontalAlignment="Center" VerticalAlignment="Top"
                         Margin="0,-200,0,0">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#2EA78BFA" Offset="0"/>
                            <GradientStop Color="#00080A0E" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>
                <Ellipse Width="760" Height="560" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                         Margin="0,0,-180,-160">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#186AA0FF" Offset="0"/>
                            <GradientStop Color="#00080A0E" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>
            </Grid>

            <!-- ============ Caption bar ============ -->
            <Grid Grid.Row="0" Background="Transparent">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                    <Image Source="/Assets/app.ico" Width="20" Height="20" Margin="0,0,10,0" VerticalAlignment="Center"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <TextBlock Text="Zapret" FontFamily="{StaticResource DisplayFont}" FontWeight="Bold" FontSize="14"
                               VerticalAlignment="Center"/>
                    <Border CornerRadius="6" BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1"
                            Padding="7,2" Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="DPI bypass" FontSize="11" Foreground="{StaticResource FgMutedBrush}"/>
                    </Border>
                    <TextBlock Text="{Binding AppVersion}" FontSize="11" FontFamily="{StaticResource MonoFont}"
                               Foreground="{StaticResource Muted2Brush}"
                               VerticalAlignment="Center" Margin="8,1,0,0"/>
                    <!-- App-update badge: shown only when a newer ZapretUI release exists; opens the page -->
                    <Button Command="{Binding OpenAppReleaseCommand}" VerticalAlignment="Center" Margin="10,0,0,0"
                            Cursor="Hand" shell:WindowChrome.IsHitTestVisibleInChrome="True"
                            Visibility="{Binding AppUpdateAvailable, Converter={StaticResource BoolToVis}}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="#26F5A623" BorderBrush="{StaticResource WarnBrush}" BorderThickness="1"
                                        CornerRadius="6" Padding="8,2">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#x2B07;" FontSize="11" Foreground="{StaticResource WarnBrush}"
                                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="{Binding AppUpdateText}" FontSize="11"
                                                   Foreground="{StaticResource WarnBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <Border HorizontalAlignment="Center" VerticalAlignment="Center" CornerRadius="8"
                        Background="{StaticResource BgBrush}" BorderBrush="{StaticResource BorderBrush2}"
                        BorderThickness="1" Padding="3"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton Style="{StaticResource ModeSegment}" Content="Простой"
                                     IsChecked="{Binding IsSimpleMode, Mode=TwoWay}"/>
                        <RadioButton Style="{StaticResource ModeSegment}" Content="Расширенный"
                                     IsChecked="{Binding IsSimpleMode, Converter={StaticResource InverseBool}, Mode=TwoWay}"/>
                    </StackPanel>
                </Border>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button x:Name="MinButton" Style="{StaticResource CaptionButton}" Click="OnMinimize">
                        <TextBlock Text="&#xE921;" FontFamily="{StaticResource IconFont}" FontSize="11"/>
                    </Button>
                    <Button x:Name="MaxButton" Style="{StaticResource CaptionButton}" Click="OnMaximizeRestore">
                        <TextBlock Text="&#xE922;" FontFamily="{StaticResource IconFont}" FontSize="11"/>
                    </Button>
                    <Button x:Name="CloseButton" Style="{StaticResource CloseButton}" Click="OnCloseClick">
                        <TextBlock Text="&#xE8BB;" FontFamily="{StaticResource IconFont}" FontSize="11"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- ============ Body: top tabs (Главная — first; strip hidden in Simple) ============ -->
            <TabControl x:Name="MainTabs" Grid.Row="1" Style="{StaticResource TopTabs}"
                        SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}"
                        SelectionChanged="OnTabsSelectionChanged">
                <TabControl.Resources>
                    <Style TargetType="TabItem" BasedOn="{StaticResource TopTabItem}"/>
                </TabControl.Resources>

                <!-- ===================== Главная ===================== -->
                <TabItem Header="Главная">
                    <Grid>
                        <!-- gear → Настройки -->
                        <Button Command="{Binding GoToSettingsCommand}" Style="{StaticResource GhostButton}"
                                HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,22,26,0"
                                Width="40" Height="40" Padding="0" ToolTip="Настройки">
                            <TextBlock Text="&#xE713;" FontFamily="{StaticResource IconFont}" FontSize="16"/>
                        </Button>

                        <!-- top banners (apply-strategy + proxy-host) -->
                        <StackPanel VerticalAlignment="Top" HorizontalAlignment="Center" MaxWidth="540" Margin="24,20,24,0">
                            <Border CornerRadius="10" Padding="12,10" Margin="0,0,0,10"
                                    Background="#1A34D399" BorderBrush="{StaticResource SuccessBrush}" BorderThickness="1"
                                    Visibility="{Binding IsStrategyChangePending, Converter={StaticResource BoolToVis}}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0"
                                               Style="{StaticResource Muted}" FontSize="11.5" TextWrapping="Wrap"
                                               Text="Чтобы применить выбранный пресет, нужно перезапустить движок."/>
                                    <Button Grid.Column="1" Content="Сменить стратегию"
                                            Command="{Binding ApplyStrategyCommand}"
                                            Style="{StaticResource StartStopButton}" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <Border CornerRadius="10" Padding="14,12" Margin="0,0,0,10"
                                    Background="#1AF5A623" BorderBrush="{StaticResource WarnBrush}" BorderThickness="1"
                                    Visibility="{Binding ShowProxyHostPrompt, Converter={StaticResource BoolToVis}}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                                        <TextBlock Text="Нужен хост вашего MTProxy" FontWeight="SemiBold"/>
                                        <TextBlock Style="{StaticResource Muted}" FontSize="11.5" TextWrapping="Wrap" Margin="0,3,0,0"
                                                   Text="Этот пресет работает через ваш прокси. Пока не укажете его «Хост» — подключение недоступно."/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="Указать хост прокси" VerticalAlignment="Center"
                                            Command="{Binding OpenProxyPromptCommand}" Style="{StaticResource StartStopButton}"/>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!-- centered status hero + one big action button -->
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="440" Margin="24"
                                    Opacity="0" RenderTransformOrigin="0.5,0.5">
                            <StackPanel.RenderTransform><TranslateTransform x:Name="homeSlide" Y="12"/></StackPanel.RenderTransform>
                            <StackPanel.Triggers>
                                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.4"/>
                                            <DoubleAnimation Storyboard.TargetName="homeSlide" Storyboard.TargetProperty="Y"
                                                             From="12" To="0" Duration="0:0:0.4">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </StackPanel.Triggers>

                            <!-- status dot + word -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,18">
                                <Ellipse Width="9" Height="9" VerticalAlignment="Center" Margin="0,0,10,0"
                                         Fill="{Binding State, Converter={StaticResource StateToBrush}}">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                    <DataTrigger.EnterActions>
                                                        <BeginStoryboard Name="HomeDot">
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                    From="1" To="0.3" Duration="0:0:1"
                                                                    AutoReverse="True" RepeatBehavior="Forever"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.EnterActions>
                                                    <DataTrigger.ExitActions>
                                                        <StopStoryboard BeginStoryboardName="HomeDot"/>
                                                    </DataTrigger.ExitActions>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock Text="{Binding State, Converter={StaticResource StateToText}}"
                                           FontFamily="{StaticResource DisplayFont}" FontSize="13" FontWeight="Bold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource FgMutedBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>

                            <!-- big two-state title -->
                            <TextBlock FontFamily="{StaticResource DisplayFont}" FontSize="30" FontWeight="Bold"
                                       HorizontalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="Выключено"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                <Setter Property="Text" Value="Защищено"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <!-- one big action button (routes by mode) -->
                            <Button Command="{Binding HomeToggleCommand}" Height="56" Width="300"
                                    HorizontalAlignment="Center" Margin="0,26,0,0">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource StartStopButton}">
                                        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                                        <Setter Property="FontSize" Value="16"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <TextBlock FontFamily="{StaticResource DisplayFont}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="&#x25B6;  Включить обход"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                    <Setter Property="Text" Value="&#x25A0;  Остановить обход"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Button>

                            <emoji:TextBlock Text="{Binding SimpleStatus}" Style="{StaticResource Muted}" FontSize="13"
                                       HorizontalAlignment="Center" TextAlignment="Center" Margin="0,20,0,0"/>

                            <!-- scope chips -->
                            <TextBlock Text="ЧТО ПОДОБРАТЬ" Style="{StaticResource Muted}" FontSize="11"
                                       HorizontalAlignment="Center" Margin="0,26,0,10"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <RadioButton Style="{StaticResource ChipButton}" Content="Discord + YouTube"
                                             IsChecked="{Binding ScopeBoth, Mode=TwoWay}"/>
                                <RadioButton Style="{StaticResource ChipButton}" Content="Discord"
                                             IsChecked="{Binding ScopeDiscord, Mode=TwoWay}"/>
                                <RadioButton Style="{StaticResource ChipButton}" Content="YouTube"
                                             IsChecked="{Binding ScopeYouTube, Mode=TwoWay}"/>
                            </StackPanel>
                            <TextBlock Text="{Binding SimpleGoalHint}" Style="{StaticResource Muted}" FontSize="11.5"
                                       HorizontalAlignment="Center" TextAlignment="Center" Margin="0,8,0,0"/>

                            <Button Content="Переподобрать под провайдера" Command="{Binding SmartPickCommand}"
                                    Style="{StaticResource GhostButton}" Margin="0,18,0,0" HorizontalAlignment="Center"/>

                            <ProgressBar Value="{Binding UpdateProgress, Mode=OneWay}" Maximum="1" Margin="0,16,0,0"
                                         Visibility="{Binding IsUpdating, Converter={StaticResource BoolToVis}}"/>
                            <TextBlock Text="{Binding UpdateStatus}" Style="{StaticResource Muted}" Margin="0,8,0,0"
                                       HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"
                                       Visibility="{Binding IsUpdating, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>

                        <!-- Telegram one-click card (Simple mode only) -->
                        <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="24,20,0,0" Width="216"
                                Style="{StaticResource Card}" Padding="16"
                                Visibility="{Binding IsSimpleMode, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="22" Height="22" CornerRadius="11" Background="#2A6AA0FF" VerticalAlignment="Center">
                                        <emoji:TextBlock Text="✈️" FontSize="12"
                                                         HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="Telegram" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center" Margin="9,0,0,0"/>
                                </StackPanel>
                                <TextBlock Style="{StaticResource Muted}" FontSize="11.5" TextWrapping="Wrap" Margin="0,10,0,0"
                                           Text="Доступ к Telegram через ваш MTProxy + веб-версия в браузере."/>
                                <Button Content="Включить для Telegram" Command="{Binding EnableTelegramCommand}"
                                        Style="{StaticResource StartStopButton}" Margin="0,12,0,0" HorizontalAlignment="Stretch"/>
                                <Button Command="{Binding OpenHowItWorksCommand}"
                                        Style="{StaticResource GhostButton}" Margin="0,8,0,0" HorizontalAlignment="Stretch">
                                    <emoji:TextBlock Text="❔  Как это работает"/>
                                </Button>
                            </StackPanel>
                        </Border>

                        <!-- Donate (bottom-left, both modes) -->
                        <ctl:DonateBlock HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="24,0,0,22"/>
                    </Grid>
                </TabItem>

                <!-- ===================== Стратегии ===================== -->
                <TabItem Header="Стратегии">
                    <Grid Margin="24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Margin="2,0,0,16">
                            <TextBlock Text="Стратегии" Style="{StaticResource H1}"/>
                            <TextBlock Style="{StaticResource Muted}" Margin="0,3,0,0"
                                       Text="Готовые комбо-пресеты на синтаксисе winws2. Хостлисты подключаются прямо к стратегии."/>
                        </StackPanel>
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="300"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource Card}" Padding="8" Margin="0,0,16,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                            <ListBox Grid.Row="0" ItemsSource="{Binding PresetsView}" SelectedItem="{Binding SelectedPreset}"
                                     ItemContainerStyle="{StaticResource SelectableItem}">
                                <ListBox.GroupStyle>
                                    <GroupStyle>
                                        <GroupStyle.HeaderTemplate>
                                            <DataTemplate>
                                                <Border Margin="2,12,2,6" Padding="0,0,0,8"
                                                        BorderBrush="{StaticResource BorderBrush2}" BorderThickness="0,0,0,1">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Border Width="3" Height="13" CornerRadius="2" Margin="0,0,8,0"
                                                                Background="{StaticResource AccentBrush}" VerticalAlignment="Center"/>
                                                        <emoji:TextBlock Text="{Binding Name}" FontSize="11" FontWeight="Bold"
                                                                   Foreground="{StaticResource FgMutedBrush}" VerticalAlignment="Center"/>
                                                        <Border CornerRadius="6" Background="{StaticResource AccentSoftBrush}"
                                                                Padding="6,1" Margin="8,0,0,0" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding ItemCount}" FontSize="10" FontWeight="Bold"
                                                                       FontFamily="{StaticResource MonoFont}"
                                                                       Foreground="{StaticResource AccentBrush}"/>
                                                        </Border>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </GroupStyle.HeaderTemplate>
                                    </GroupStyle>
                                </ListBox.GroupStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <Grid>
                                                <emoji:TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis" Margin="0,0,64,0"/>
                                                <!-- "ВКЛЮЧЁН" badge — visible only on the actually-running preset -->
                                                <Border CornerRadius="5" Padding="6,1" HorizontalAlignment="Right"
                                                        Background="#2634D399" VerticalAlignment="Center">
                                                    <Border.Visibility>
                                                        <MultiBinding Converter="{StaticResource RefEqualsToVis}">
                                                            <Binding Path="."/>
                                                            <Binding Path="DataContext.RunningPreset"
                                                                     RelativeSource="{RelativeSource AncestorType=ListBox}"/>
                                                        </MultiBinding>
                                                    </Border.Visibility>
                                                    <TextBlock Text="ВКЛЮЧЁН" FontSize="9.5" FontWeight="Bold"
                                                               Foreground="{StaticResource SuccessBrush}"/>
                                                </Border>
                                            </Grid>
                                            <TextBlock Text="{Binding Description}" Style="{StaticResource Muted}"
                                                       FontSize="11.5" TextTrimming="CharacterEllipsis" MaxHeight="32"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <Button Grid.Row="1" Command="{Binding OpenHowItWorksCommand}"
                                    Style="{StaticResource GhostButton}" Margin="4,8,4,4" HorizontalAlignment="Stretch">
                                <emoji:TextBlock Text="❔  Как это работает"/>
                            </Button>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource Card}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <emoji:TextBlock Grid.Row="0" Text="{Binding SelectedPreset.Name, FallbackValue='Выберите пресет'}"
                                           Style="{StaticResource H2}" TextWrapping="Wrap"/>

                                <!-- Row 2 holds EITHER the readable description (default) OR the raw-args editor.
                                     The editor is opt-in via the «Аргументы движка» button (declutter). -->
                                <Grid Grid.Row="2" Margin="0,10,0,0">
                                    <!-- Default: clean, readable description + a contextual help card filling the space -->
                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                  Visibility="{Binding ShowPresetArgs, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
                                        <StackPanel>
                                            <TextBlock Text="{Binding SelectedPreset.Description}" TextWrapping="Wrap"
                                                       FontSize="13.5" LineHeight="20" Foreground="{StaticResource FgBrush}"/>

                                            <!-- Telegram-proxy specific note -->
                                            <Border CornerRadius="10" Padding="14,12" Margin="0,16,0,0"
                                                    Background="#142CC0A0" BorderBrush="{StaticResource SuccessBrush}" BorderThickness="1"
                                                    Visibility="{Binding SelectedPreset.RequiresProxyHost, Converter={StaticResource BoolToVis}}">
                                                <StackPanel>
                                                    <TextBlock Text="Это про подключение к ВАШЕМУ прокси" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                                    <TextBlock Style="{StaticResource Muted}" FontSize="12" TextWrapping="Wrap"
                                                               Text="Пресет НЕ чинит сам прокси и не «лечит» Telegram напрямую — он помогает вашему клиенту дозвониться до MTProxy и заодно чинит веб-версию (web.telegram.org в браузере). Включите пресет → в Telegram подключайтесь именно через ваш прокси.(Как только подключитесь - Вас от него не отключит и вы можете менять стратегию на любую другую)"/>
                                                </StackPanel>
                                            </Border>

                                            <!-- General help / app tour entry -->
                                            <Border CornerRadius="10" Padding="14,12" Margin="0,12,0,0"
                                                    Background="{StaticResource BgBrush}" BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1">
                                                <StackPanel>
                                                    <TextBlock Text="Не заработало?" FontWeight="SemiBold"/>
                                                    <TextBlock Style="{StaticResource Muted}" FontSize="12" TextWrapping="Wrap" Margin="0,4,0,0"
                                                               Text="Стратегии зависят от провайдера. Если этот пресет не пробивает — попробуйте другие из списка. Если ничего не заходит — вкладка «Диагностика» → «Подобрать лучшую» подберёт рабочую стратегию под вашего оператора."/>
                                                    <Button Command="{Binding OpenHowItWorksCommand}"
                                                            Style="{StaticResource GhostButton}" HorizontalAlignment="Left" Margin="0,10,0,0">
                                                        <emoji:TextBlock Text="❔  Как это работает — экскурс по приложению"/>
                                                    </Button>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </ScrollViewer>
                                    <!-- Opt-in: in-app args editor, styled as a terminal -->
                                    <Border Visibility="{Binding ShowPresetArgs, Converter={StaticResource BoolToVis}}"
                                            Background="{StaticResource BgBrush}" CornerRadius="12"
                                            BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1" ClipToBounds="True">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <!-- terminal title bar -->
                                            <Border Grid.Row="0" Background="#10FFFFFF" Padding="12,9"
                                                    BorderBrush="{StaticResource BorderBrush2}" BorderThickness="0,0,0,1">
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse Width="9" Height="9" Fill="#FFE2566A" Margin="0,0,6,0"/>
                                                    <Ellipse Width="9" Height="9" Fill="#FFF5C451" Margin="0,0,6,0"/>
                                                    <Ellipse Width="9" Height="9" Fill="#FF34D399" Margin="0,0,10,0"/>
                                                    <TextBlock Text="аргументы winws2 (по одному в строке)"
                                                               FontFamily="{StaticResource MonoFont}" FontSize="11"
                                                               Foreground="{StaticResource Muted2Brush}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                            <TextBox Grid.Row="1" Text="{Binding PresetArgsText, UpdateSourceTrigger=PropertyChanged}"
                                                     IsReadOnly="{Binding SelectedPresetEditable, Converter={StaticResource InverseBool}}"
                                                     AcceptsReturn="True" TextWrapping="NoWrap" Background="Transparent" BorderThickness="0"
                                                     VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                                     FontFamily="{StaticResource MonoFont}" FontSize="12"/>
                                            <!-- fully-expanded command that will actually run -->
                                            <StackPanel Grid.Row="2" Margin="12,8,12,12">
                                                <TextBlock Text="ЗАПУСК" Style="{StaticResource Muted}" FontSize="10"/>
                                                <TextBlock Text="{Binding CommandPreview}" FontFamily="{StaticResource MonoFont}"
                                                           FontSize="11.5" Foreground="{StaticResource FgMutedBrush}"
                                                           TextWrapping="Wrap" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Grid>

                                <StackPanel Grid.Row="3" Margin="0,14,0,0">
                                    <!-- Apply-strategy banner: a strategy change needs an engine restart,
                                         so the user confirms it explicitly here. -->
                                    <Border CornerRadius="8" Padding="12,10" Margin="0,0,0,12"
                                            Background="#1A34D399" BorderBrush="{StaticResource SuccessBrush}" BorderThickness="1"
                                            Visibility="{Binding IsStrategyChangePending, Converter={StaticResource BoolToVis}}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                                                <TextBlock Text="Выбрана другая стратегия" FontWeight="SemiBold" FontSize="12.5"/>
                                                <TextBlock Style="{StaticResource Muted}" FontSize="11.5" TextWrapping="Wrap"
                                                           Text="{Binding RunningPresetName, StringFormat='Сейчас включён: {0}. Смена стратегии требует перезапуска движка.'}"/>
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="Сменить стратегию"
                                                    Command="{Binding ApplyStrategyCommand}"
                                                    Style="{StaticResource StartStopButton}" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>

                                    <StackPanel Orientation="Horizontal">
                                        <Button Command="{Binding TogglePresetArgsCommand}"
                                                Style="{StaticResource GhostButton}" Margin="0,0,8,0">
                                            <TextBlock>
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="Аргументы движка"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding ShowPresetArgs}" Value="True">
                                                                <Setter Property="Text" Value="Скрыть аргументы"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Button>
                                        <Button Content="Дублировать" Command="{Binding DuplicatePresetCommand}"
                                                Style="{StaticResource GhostButton}" Margin="0,0,8,0"/>
                                        <Button Content="Сохранить" Command="{Binding SavePresetCommand}"
                                                Style="{StaticResource GhostButton}" Margin="0,0,8,0"/>
                                        <Button Content="Удалить" Command="{Binding DeletePresetCommand}"
                                                Style="{StaticResource GhostButton}"/>
                                        <TextBlock Text="Встроенный — дублируйте для правки"
                                                   Style="{StaticResource Muted}" VerticalAlignment="Center" Margin="14,0,0,0"
                                                   Visibility="{Binding SelectedPresetEditable, Converter={StaticResource BoolToVis}, ConverterParameter=invert}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>
                        </Grid>
                    </Grid>
                </TabItem>

                <!-- Хостлисты -->
                <TabItem Header="Хостлисты">
                    <Grid Margin="24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Margin="2,0,0,16">
                            <TextBlock Text="Хостлисты" Style="{StaticResource H1}"/>
                            <TextBlock Style="{StaticResource Muted}" Margin="0,3,0,0"
                                       Text="Списки доменов, к которым применяется обход. Один домен — одна строка. Список «proxy» — адрес вашего MTProxy."/>
                        </StackPanel>
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="240"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource Card}" Padding="8" Margin="0,0,16,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <ListBox Grid.Row="0" ItemsSource="{Binding Hostlists}"
                                         SelectedItem="{Binding SelectedHostlist}"
                                         ItemContainerStyle="{StaticResource SelectableItem}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="28" Height="28" CornerRadius="8" VerticalAlignment="Center"
                                                        Background="{StaticResource AccentSoftBrush}"
                                                        BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1">
                                                    <emoji:TextBlock Text="📄" FontSize="13"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock Text="{Binding}" FontFamily="{StaticResource MonoFont}"
                                                           FontSize="13" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <Button Grid.Row="1" Content="+ Новый список" Command="{Binding NewHostlistCommand}"
                                        Style="{StaticResource GhostButton}" Margin="4,8,4,4"/>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource Card}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="{Binding SelectedHostlist, FallbackValue='Выберите или создайте список'}"
                                           FontFamily="{StaticResource MonoFont}" FontSize="16" FontWeight="Bold"/>

                                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,12">
                                    <TextBox Width="300" Text="{Binding NewDomain, UpdateSourceTrigger=PropertyChanged}"/>
                                    <Button Content="Добавить домен" Command="{Binding AddDomainCommand}"
                                            Style="{StaticResource GhostButton}" Margin="8,0,0,0"/>
                                </StackPanel>

                                <TextBox Grid.Row="2" Text="{Binding HostlistContent, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True" TextWrapping="NoWrap" Background="{StaticResource BgBrush}"
                                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                         FontFamily="{StaticResource MonoFont}" FontSize="12.5"/>

                                <StackPanel Grid.Row="3" Margin="0,14,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Сохранить список" Command="{Binding SaveHostlistCommand}"
                                                Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"/>
                                        <Button Content="Удалить список" Command="{Binding DeleteHostlistCommand}"
                                                Style="{StaticResource GhostButton}"/>
                                    </StackPanel>
                                    <!-- Noticeable note about the special "proxy" list (Path-2 surgical scoping) -->
                                    <Border CornerRadius="8" Padding="12,10" Margin="0,12,0,0"
                                            Background="#1A6AA0FF" BorderBrush="{StaticResource AccentBrush}" BorderThickness="1">
                                        <TextBlock Style="{StaticResource Muted}" FontSize="11.5" TextWrapping="Wrap"
                                                   Text="Список «proxy» — это адрес вашего MTProxy (поле «Хост» из настроек прокси Telegram) для пресета «Комбо + Telegram (через мой прокси)». Одна строка = хост. После сохранения он автоматически пере-резолвится в IP, чтобы десинк бил точно по прокси и не задевал YouTube/Discord."/>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>
                        </Grid>
                    </Grid>
                </TabItem>

                <!-- Диагностика: автоподбор/генератор + матрица -->
                <TabItem Header="Диагностика">
                    <Grid Margin="24">
                        <Grid.Resources>
                            <CollectionViewSource x:Key="GroupedDiag" Source="{Binding DiagRows}">
                                <CollectionViewSource.GroupDescriptions>
                                    <PropertyGroupDescription PropertyName="Group"/>
                                </CollectionViewSource.GroupDescriptions>
                            </CollectionViewSource>
                        </Grid.Resources>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" MinWidth="360" MaxWidth="480"/>
                            <ColumnDefinition Width="3*" MinWidth="440"/>
                        </Grid.ColumnDefinitions>

                        <!-- LEFT: подбор / цели / генерация — scrolls as a whole, scales with window -->
                        <ScrollViewer Grid.Column="0" Margin="0,0,16,0" VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel>

                            <!-- Card: auto-select + generate + scope + results -->
                            <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Text="Проверка и авто-подбор" Style="{StaticResource H2}"/>
                                <TextBlock Style="{StaticResource Muted}" Margin="0,6,0,0" TextWrapping="Wrap"
                                           Text="«Подобрать лучшую» ищет рабочую стратегию по выбранной цели, «Диагностика» — показывает текущую доступность."/>

                                <!-- Scope -->
                                <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                                    <TextBlock Text="ЦЕЛЬ ПОДБОРА" Style="{StaticResource Muted}" FontSize="11"
                                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <Border CornerRadius="8" Background="{StaticResource BgBrush}"
                                            BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1" Padding="3">
                                        <StackPanel Orientation="Horizontal">
                                            <RadioButton Style="{StaticResource ModeSegment}" Content="DC + YT"
                                                         IsChecked="{Binding ScopeBoth, Mode=TwoWay}"/>
                                            <RadioButton Style="{StaticResource ModeSegment}" Content="Discord"
                                                         IsChecked="{Binding ScopeDiscord, Mode=TwoWay}"/>
                                            <RadioButton Style="{StaticResource ModeSegment}" Content="YouTube"
                                                         IsChecked="{Binding ScopeYouTube, Mode=TwoWay}"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <!-- Actions (wrap — compact, flows to the left column width) -->
                                <WrapPanel Margin="0,14,0,0">
                                    <Button Content="Подобрать лучшую" Command="{Binding RunAutoSelectCommand}"
                                            Style="{StaticResource PrimaryButton}" Margin="0,0,8,8"
                                            Visibility="{Binding IsAutoSelecting, Converter={StaticResource BoolToVis}, ConverterParameter=invert}"/>
                                    <Button Content="Остановить подбор" Command="{Binding StopAutoSelectCommand}"
                                            Style="{StaticResource GhostButton}" Margin="0,0,8,8"
                                            Visibility="{Binding IsAutoSelecting, Converter={StaticResource BoolToVis}}"/>
                                    <Button Command="{Binding GenerateStrategyCommand}"
                                            Style="{StaticResource GhostButton}" Margin="0,0,8,8"
                                            ToolTip="Соберёт ПЕРСОНАЛЬНУЮ стратегию: тестирует компоненты и оптимизирует Discord и YouTube по отдельности, затем собирает в одно комбо (≈1 мин)."
                                            Visibility="{Binding IsGenerating, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
                                        <emoji:TextBlock Text="✨ Сгенерировать стратегию"/>
                                    </Button>
                                    <Button Content="Остановить генерацию" Command="{Binding StopAutoSelectCommand}"
                                            Style="{StaticResource GhostButton}" Margin="0,0,8,8"
                                            Visibility="{Binding IsGenerating, Converter={StaticResource BoolToVis}}"/>
                                    <Button Content="Диагностика" Command="{Binding RunDiagnosticsCommand}"
                                            Style="{StaticResource GhostButton}" Margin="0,0,8,8"
                                            Visibility="{Binding IsDiagnosing, Converter={StaticResource BoolToVis}, ConverterParameter=invert}"/>
                                    <Button Content="Остановить" Command="{Binding StopDiagnosticsCommand}"
                                            Style="{StaticResource GhostButton}" Margin="0,0,8,8"
                                            Visibility="{Binding IsDiagnosing, Converter={StaticResource BoolToVis}}"/>
                                </WrapPanel>

                                <emoji:TextBlock Text="{Binding AutoStatusText}" Style="{StaticResource Muted}"
                                           Margin="0,12,0,0" TextWrapping="Wrap"/>

                                <!-- Successful strategies (the live run happens in the popup window) -->
                                <TextBlock Text="УСПЕШНЫЕ СТРАТЕГИИ" FontSize="11" Margin="0,14,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource Muted}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding AutoScores.Count}" Value="0">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <ScrollViewer Margin="0,8,0,0" MaxHeight="260" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding AutoScores}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="8" Background="{StaticResource BgBrush}"
                                                        BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1"
                                                        Margin="0,0,0,6" Opacity="0">
                                                    <Border.Triggers>
                                                        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                                            <BeginStoryboard>
                                                                <Storyboard>
                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                        From="0" To="1" Duration="0:0:0.28"/>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </EventTrigger>
                                                    </Border.Triggers>
                                                    <StackPanel>
                                                        <!-- header row -->
                                                        <Grid Margin="12,8">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="{Binding Glyph}" FontWeight="Bold"
                                                                       FontSize="14" VerticalAlignment="Center">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="{StaticResource FgMutedBrush}"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Glyph}" Value="✓">
                                                                                <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Glyph}" Value="≈">
                                                                                <Setter Property="Foreground" Value="#FFF5A623"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Glyph}" Value="✗">
                                                                                <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                            <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                                                <TextBlock Text="{Binding Detail}" Style="{StaticResource Muted}" FontSize="11.5"/>
                                                            </StackPanel>
                                                            <Button Grid.Column="2" Content="Сохранить в пресеты"
                                                                    Style="{StaticResource GhostButton}" Padding="10,5" FontSize="12"
                                                                    Command="{Binding DataContext.ApplyScoreCommand,
                                                                              RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                    CommandParameter="{Binding}"/>
                                                            <ToggleButton x:Name="exp" Grid.Column="3" Style="{StaticResource ChevronToggle}"
                                                                          Margin="4,0,0,0" VerticalAlignment="Center"/>
                                                        </Grid>
                                                        <!-- expandable per-endpoint detail -->
                                                        <ItemsControl ItemsSource="{Binding HostList}" Margin="14,0,14,10"
                                                                      Visibility="{Binding IsChecked, ElementName=exp, Converter={StaticResource BoolToVis}}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Grid Margin="0,3">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*"/>
                                                                            <ColumnDefinition Width="120"/>
                                                                            <ColumnDefinition Width="120"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBlock Grid.Column="0" Text="{Binding Host}"
                                                                                   Style="{StaticResource Muted}" VerticalAlignment="Center"/>
                                                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                                            <TextBlock Text="TLS 1.2 " Style="{StaticResource Muted}" FontSize="11"/>
                                                                            <TextBlock Text="{Binding Tls12, Converter={StaticResource DiagText}}"
                                                                                       Foreground="{Binding Tls12, Converter={StaticResource DiagBrush}}"
                                                                                       FontWeight="SemiBold" FontSize="11.5"/>
                                                                        </StackPanel>
                                                                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                                            <TextBlock Text="TLS 1.3 " Style="{StaticResource Muted}" FontSize="11"/>
                                                                            <TextBlock Text="{Binding Tls13, Converter={StaticResource DiagText}}"
                                                                                       Foreground="{Binding Tls13, Converter={StaticResource DiagBrush}}"
                                                                                       FontWeight="SemiBold" FontSize="11.5"/>
                                                                        </StackPanel>
                                                                    </Grid>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <Border Background="#22F59E0B" CornerRadius="6" Padding="10,7" Margin="0,4,0,0">
                                    <TextBlock Text="{Binding DiagEngineNote}" TextWrapping="Wrap"
                                               FontSize="11.5" Foreground="#FFFBBF24"/>
                                </Border>

                                <Grid Margin="0,12,0,0">
                                    <TextBlock Text="{Binding DiagStatusText}" Style="{StaticResource Muted}"
                                               HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding DiagSummary}" FontWeight="SemiBold" FontSize="12.5"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                            </Border>

                            <!-- Свои цели (custom bypass targets) -->
                            <Border Style="{StaticResource Card}" Margin="0,16,0,0">
                                <StackPanel>
                                    <TextBlock Text="Свои цели" Style="{StaticResource H2}"/>
                                    <TextBlock Style="{StaticResource Muted}" Margin="0,6,0,0" TextWrapping="Wrap"
                                               Text="Добавьте свой сайт — приложение найдёт его поддомены и домены того же бренда на других зонах (yandex.ru → yandex.kz/md…), будет проверять их в диагностике, учитывать при подборе и генерации и применять к ним обход."/>

                                    <ItemsControl ItemsSource="{Binding CustomTargets}" Margin="0,12,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="9" Background="{StaticResource BgBrush}"
                                                        BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1"
                                                        Padding="12,9" Margin="0,0,0,6">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                                       FontFamily="{StaticResource MonoFont}" FontSize="13"/>
                                                            <TextBlock Text="{Binding Subtitle}" Style="{StaticResource Muted}" FontSize="11"/>
                                                        </StackPanel>
                                                        <Button Grid.Column="1" Content="Открыть" Style="{StaticResource GhostButton}"
                                                                Padding="10,5" FontSize="12" VerticalAlignment="Center"
                                                                Command="{Binding DataContext.OpenTargetCommand,
                                                                          RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding}"/>
                                                        <Button Grid.Column="2" Content="✕" Style="{StaticResource GhostButton}"
                                                                Padding="9,5" FontSize="12" MinWidth="0" Margin="6,0,0,0" VerticalAlignment="Center"
                                                                Command="{Binding DataContext.DeleteTargetCommand,
                                                                          RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding}"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <TextBlock FontSize="11.5" Margin="0,2,0,8" Text="Целей пока нет.">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource Muted}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CustomTargets.Count}" Value="0">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <Button Content="+ Добавить цель" Command="{Binding AddTargetCommand}"
                                            Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- RIGHT: матрица сервисов (тянется по ширине окна) -->
                        <Border Grid.Column="1" Style="{StaticResource Card}" Padding="6">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <!-- Column headers -->
                                <Grid Grid.Row="0" Margin="14,8,14,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="70"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="СЕРВИС / ТОЧКА" Style="{StaticResource Muted}" FontSize="11"/>
                                    <TextBlock Grid.Column="1" Text="HTTP" Style="{StaticResource Muted}" FontSize="11" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="TLS 1.2" Style="{StaticResource Muted}" FontSize="11" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="3" Text="TLS 1.3" Style="{StaticResource Muted}" FontSize="11" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Column="4" Text="ПИНГ" Style="{StaticResource Muted}" FontSize="11" HorizontalAlignment="Center"/>
                                </Grid>
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                <ItemsControl ItemsSource="{Binding Source={StaticResource GroupedDiag}}">
                                    <ItemsControl.GroupStyle>
                                        <GroupStyle>
                                            <GroupStyle.HeaderTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12.5"
                                                               Foreground="{StaticResource AccentBrush}" Margin="10,12,0,4"/>
                                                </DataTemplate>
                                            </GroupStyle.HeaderTemplate>
                                        </GroupStyle>
                                    </ItemsControl.GroupStyle>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="14,7" Margin="0,1" CornerRadius="6" Background="{StaticResource BgBrush}"
                                                    Opacity="0">
                                                <Border.Triggers>
                                                    <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                    From="0" To="1" Duration="0:0:0.3"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </EventTrigger>
                                                </Border.Triggers>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="70"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                                        <TextBlock Text="{Binding Host}" Style="{StaticResource Muted}" FontSize="10.5"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1" Text="{Binding Http, Converter={StaticResource DiagText}}"
                                                               Foreground="{Binding Http, Converter={StaticResource DiagBrush}}"
                                                               FontWeight="SemiBold" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding Tls12, Converter={StaticResource DiagText}}"
                                                               Foreground="{Binding Tls12, Converter={StaticResource DiagBrush}}"
                                                               FontWeight="SemiBold" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="3" Text="{Binding Tls13, Converter={StaticResource DiagText}}"
                                                               Foreground="{Binding Tls13, Converter={StaticResource DiagBrush}}"
                                                               FontWeight="SemiBold" FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="4" Text="{Binding PingText}"
                                                               Foreground="{Binding Ping, Converter={StaticResource DiagBrush}}"
                                                               FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                </ScrollViewer>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- Логи -->
                <TabItem Header="Журнал">
                    <Grid Margin="24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="2,0,0,12">
                            <TextBlock Text="Журнал движка" Style="{StaticResource H1}" VerticalAlignment="Center"/>
                            <Border CornerRadius="6" BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1"
                                    Padding="7,2" Margin="12,2,0,0" VerticalAlignment="Center">
                                <TextBlock Text="--debug" FontFamily="{StaticResource MonoFont}" FontSize="11"
                                           Foreground="{StaticResource Muted2Brush}"/>
                            </Border>
                            <Button Content="Очистить" Command="{Binding ClearLogCommand}"
                                    Style="{StaticResource GhostButton}" Margin="16,0,0,0"/>
                        </StackPanel>
                        <Border Grid.Row="1" Background="{StaticResource BgBrush}" CornerRadius="13" Padding="8"
                                BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1">
                            <ListBox x:Name="LogList" ItemsSource="{Binding LogLines}"
                                     VirtualizingPanel.IsVirtualizing="True"
                                     ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Padding" Value="6,1"/>
                                        <Setter Property="Foreground" Value="{StaticResource FgMutedBrush}"/>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontFamily="{StaticResource MonoFont}"
                                                   FontSize="12" TextWrapping="NoWrap"
                                                   Foreground="{StaticResource FgMutedBrush}"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- Настройки -->
                <TabItem Header="Настройки">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
                        <StackPanel MaxWidth="640" HorizontalAlignment="Left">
                            <TextBlock Text="Настройки" Style="{StaticResource H1}" Margin="2,0,0,16"/>
                            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                                <StackPanel>
                                    <TextBlock Text="Движок" Style="{StaticResource H2}" Margin="0,0,0,12"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <TextBlock Text="Установленная версия:" Style="{StaticResource Muted}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding EngineVersion}" Margin="8,0,0,0" VerticalAlignment="Center"
                                                   FontWeight="SemiBold"/>
                                        <Button Content="Проверить обновления" Command="{Binding CheckUpdateCommand}"
                                                Style="{StaticResource GhostButton}" Margin="16,0,0,0"/>
                                    </StackPanel>
                                    <CheckBox Content="Автоматически обновлять движок при запуске"
                                              IsChecked="{Binding AutoUpdateEngine}" Style="{StaticResource ToggleSwitch}"
                                              Margin="0,4"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="Запуск" Style="{StaticResource H2}" Margin="0,0,0,12"/>
                                    <CheckBox Content="Запускать Zapret UI при входе в Windows"
                                              IsChecked="{Binding AutostartEnabled}" Style="{StaticResource ToggleSwitch}"
                                              Margin="0,6"/>
                                    <CheckBox Content="Сразу запускать обход при старте приложения"
                                              IsChecked="{Binding AutostartEngine}" Style="{StaticResource ToggleSwitch}"
                                              Margin="0,6"/>
                                    <CheckBox Content="Сворачивать в трей вместо закрытия"
                                              IsChecked="{Binding MinimizeToTray}" Style="{StaticResource ToggleSwitch}"
                                              Margin="0,6"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource Card}" Margin="0,16,0,0">
                                <StackPanel>
                                    <TextBlock Text="Авто-починка" Style="{StaticResource H2}" Margin="0,0,0,8"/>
                                    <TextBlock Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,10"
                                               Text="Приложение фоном следит за доступностью Discord и YouTube. Если обход вдруг перестал работать — само переподбирает рабочую стратегию и перезапускает, без вашего участия."/>
                                    <CheckBox Content="Сам переподбирать обход, если он сломался"
                                              IsChecked="{Binding AutoHeal}" Style="{StaticResource ToggleSwitch}"
                                              Margin="0,4"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource Card}" Margin="0,16,0,0">
                                <StackPanel>
                                    <TextBlock Text="Область обхода" Style="{StaticResource H2}" Margin="0,0,0,8"/>
                                    <TextBlock Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,10"
                                               Text="По умолчанию ВЫКЛ — обходятся только YouTube, Discord, Telegram и ваши «Свои цели»/хостлисты, остальной трафик не трогается, поэтому игры и приложения не ломаются (как у Flowseal). Включите, чтобы обходить ЛЮБОЙ заблокированный сайт автоматически (десинк на весь TLS/QUIC, кроме списка исключений) — удобно, но может сломать игру/приложение, которого нет в исключениях. Меняется на лету."/>
                                    <CheckBox Content="Обходить все сайты, а не только из списков"
                                              IsChecked="{Binding BypassAllSites}" Style="{StaticResource ToggleSwitch}"
                                              Margin="0,4"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource Card}" Margin="0,16,0,0">
                                <StackPanel>
                                    <TextBlock Text="Игровой фильтр" Style="{StaticResource H2}" Margin="0,0,0,8"/>
                                    <TextBlock Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,10"
                                               Text="По умолчанию ВЫКЛ — обход не трогает игровой трафик (высокие порты), игры работают напрямую. Включите, только если душат саму игру: обход распространится на все порты выше 1023 (заодно покроет Discord-медиа на высоких портах). Меняется на лету — движок перезапустится."/>
                                    <CheckBox Content="Распространять обход на игровые порты (>1023)"
                                              IsChecked="{Binding GameFilter}" Style="{StaticResource ToggleSwitch}"
                                              Margin="0,4"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource Card}" Margin="0,16,0,0">
                                <StackPanel>
                                    <TextBlock Text="Обход по IP (для жёстких блоков)" Style="{StaticResource H2}" Margin="0,0,0,8"/>
                                    <TextBlock Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,10"
                                               Text="Если Discord режут по IP-адресам, обход по доменам не помогает. Соберите актуальные подсети Discord (резолв доменов) — список сохранится в ipset-discord.txt, его можно подключить в своём пресете через токен {IPSET}."/>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Собрать IP-список Discord" Command="{Binding BuildDiscordIpsetCommand}"
                                                Style="{StaticResource GhostButton}"
                                                Visibility="{Binding IsBuildingIpset, Converter={StaticResource BoolToVis}, ConverterParameter=invert}"/>
                                        <TextBlock Text="Собираю…" Style="{StaticResource Muted}" VerticalAlignment="Center"
                                                   Visibility="{Binding IsBuildingIpset, Converter={StaticResource BoolToVis}}"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding IpsetStatus}" Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,10,0,0"/>

                                    <Border Height="1" Background="{StaticResource BorderBrush2}" Margin="0,16,0,14"/>

                                    <TextBlock Text="Telegram (по IP)" Style="{StaticResource H2}" Margin="0,0,0,8"/>
                                    <TextBlock Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,0,0,10"
                                               Text="Telegram замедляют по QUIC (UDP 443). Комбо-пресеты шлют QUIC-фейк (google-блоб) и по доменам (хостлист telegram), и по подсетям дата-центров (ipset) — в РФ это ускоряет и веб, и приложение. Список подсетей засевается автоматически; кнопка ниже обновляет его с официального фида Telegram. Если у твоего провайдера не помогло — остаётся WARP / MTProto-прокси / tg-ws-proxy."/>
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Собрать IP-список Telegram" Command="{Binding BuildTelegramIpsetCommand}"
                                                Style="{StaticResource GhostButton}"
                                                Visibility="{Binding IsBuildingIpset, Converter={StaticResource BoolToVis}, ConverterParameter=invert}"/>
                                        <TextBlock Text="Собираю…" Style="{StaticResource Muted}" VerticalAlignment="Center"
                                                   Visibility="{Binding IsBuildingIpset, Converter={StaticResource BoolToVis}}"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding TelegramIpsetStatus}" Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,10,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>

            <!-- ============ Modal: enter your MTProxy host ============ -->
            <Grid Grid.Row="0" Grid.RowSpan="2" Panel.ZIndex="100" Background="#C0000000"
                  Visibility="{Binding ShowProxyPopup, Converter={StaticResource BoolToVis}}">
                <Border Style="{StaticResource ModalCard}" MaxWidth="430" MaxHeight="640"
                        VerticalAlignment="Center" HorizontalAlignment="Center"
                        BorderBrush="{StaticResource AccentBrush}" BorderThickness="1">
                    <Border.RenderTransform><ScaleTransform/></Border.RenderTransform>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Grid>
                                <TextBlock Text="Укажите хост вашего MTProxy" Style="{StaticResource H2}"/>
                                <Button Content="✕" Command="{Binding CloseProxyPromptCommand}"
                                        Style="{StaticResource GhostButton}" HorizontalAlignment="Right"
                                        VerticalAlignment="Top" Padding="9,2" MinWidth="0"/>
                            </Grid>
                            <TextBlock Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,6,0,0"
                                       Text="Пресет десинкует подключение ТОЛЬКО к вашему прокси-серверу (по его IP), чтобы не задеть YouTube/Discord. Откройте в Telegram настройки прокси и скопируйте поле «Хост» (см. ниже). Пока не укажете — подключение недоступно. Если вы работаете в ВЕБ версии то можете указать что угодно и добавить его."/>

                            <!-- Illustrative mockup of Telegram's «Редактирование прокси» dialog -->
                            <Border Background="{StaticResource BgBrush}" BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1"
                                    CornerRadius="10" Padding="14" Margin="0,12,0,0" HorizontalAlignment="Left" Width="320">
                                <StackPanel>
                                    <TextBlock Text="Редактирование прокси" FontWeight="SemiBold" FontSize="13"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                        <Grid Width="14" Height="14" VerticalAlignment="Center">
                                            <Ellipse Stroke="{StaticResource AccentBrush}" StrokeThickness="2"/>
                                            <Ellipse Width="6" Height="6" Fill="{StaticResource AccentBrush}"/>
                                        </Grid>
                                        <TextBlock Text="MTPROTO" Margin="8,0,0,0" VerticalAlignment="Center" FontSize="12"/>
                                    </StackPanel>
                                    <TextBlock Text="Адрес сокета" Style="{StaticResource Muted}" FontSize="11" Margin="0,12,0,4"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="68"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Margin="0,0,8,0" CornerRadius="6" Padding="8,6"
                                                Background="#1F6AA0FF" BorderBrush="{StaticResource AccentBrush}" BorderThickness="1.5">
                                            <StackPanel>
                                                <TextBlock Text="Хост" FontSize="9.5" Foreground="{StaticResource AccentBrush}"/>
                                                <TextBlock Text="telegr••••••••" FontSize="12" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Column="1" CornerRadius="6" Padding="8,6"
                                                BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1">
                                            <StackPanel>
                                                <TextBlock Text="Порт" FontSize="9.5" Style="{StaticResource Muted}"/>
                                                <TextBlock Text="443" FontSize="12" Margin="0,2,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                    <TextBlock Text="↑ нужно скопировать именно поле «Хост»" FontSize="10.5"
                                               Foreground="{StaticResource AccentBrush}" Margin="0,6,0,0"/>
                                    <TextBlock Text="Ключ" Style="{StaticResource Muted}" FontSize="11" Margin="0,10,0,4"/>
                                    <Border CornerRadius="6" Padding="8,6" BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1">
                                        <TextBlock Text="ee••••••••••••••••" FontSize="12" Foreground="{StaticResource FgMutedBrush}"/>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="Хост прокси" Style="{StaticResource Muted}" Margin="0,14,0,4"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Margin="0,0,8,0"
                                         Text="{Binding ProxyHostInput, UpdateSourceTrigger=PropertyChanged}"/>
                                <Button Grid.Column="1" Content="Сохранить" Command="{Binding ApplyProxyHostCommand}"
                                        Style="{StaticResource StartStopButton}"/>
                            </Grid>
                            <TextBlock Text="{Binding ProxyHostStatus}" Style="{StaticResource Muted}" FontSize="11.5"
                                       TextWrapping="Wrap" Margin="0,8,0,0"/>
                            <TextBlock Style="{StaticResource Muted}" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"
                                       Text="Изменить хост позже — на вкладке «Хостлисты», список «proxy»."/>
                            <Button Content="Закрыть" Command="{Binding CloseProxyPromptCommand}"
                                    Style="{StaticResource GhostButton}" HorizontalAlignment="Right" Margin="0,12,0,0"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- ============ Modal: how it works / app tour ============ -->
            <Grid Grid.Row="0" Grid.RowSpan="2" Panel.ZIndex="100" Background="#C0000000"
                  Visibility="{Binding ShowHowItWorks, Converter={StaticResource BoolToVis}}">
                <Border Style="{StaticResource ModalCard}" MaxWidth="520" MaxHeight="640"
                        VerticalAlignment="Center" HorizontalAlignment="Center"
                        BorderBrush="{StaticResource AccentBrush}" BorderThickness="1">
                    <Border.RenderTransform><ScaleTransform/></Border.RenderTransform>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Grid>
                                <TextBlock Text="Как это работает" Style="{StaticResource H2}"/>
                                <Button Content="✕" Command="{Binding CloseHowItWorksCommand}"
                                        Style="{StaticResource GhostButton}" HorizontalAlignment="Right"
                                        VerticalAlignment="Top" Padding="9,2" MinWidth="0"/>
                            </Grid>

                            <TextBlock Style="{StaticResource Muted}" FontSize="12.5" TextWrapping="Wrap" Margin="0,8,0,0"
                                       Text="Zapret UI обходит блокировки и замедления (DPI) для Discord, YouTube и Telegram. Внутри работает движок winws2 — он на лету «ломает» распознавание трафика провайдером, не меняя сами сайты. Для работы нужны права администратора (запрашиваются при старте)."/>

                            <!-- 1. Быстрый старт -->
                            <TextBlock Text="1. С чего начать" FontWeight="Bold" Margin="0,16,0,4"
                                       FontFamily="{StaticResource DisplayFont}"/>
                            <TextBlock Style="{StaticResource Muted}" FontSize="12.5" TextWrapping="Wrap"
                                       Text="На вкладке «Главная» нажмите большую кнопку «Включить обход» — приложение применит рекомендуемый набор и запустит обход. Сверху можно выбрать цель (Discord + YouTube / только Discord / только YouTube). Если не помогло — ссылка «Переподобрать под провайдера» подберёт рабочую стратегию под вашу сеть."/>

                            <!-- 2. Простой / Расширенный -->
                            <TextBlock Text="2. Два режима" FontWeight="Bold" Margin="0,14,0,4"
                                       FontFamily="{StaticResource DisplayFont}"/>
                            <TextBlock Style="{StaticResource Muted}" FontSize="12.5" TextWrapping="Wrap"
                                       Text="Переключатель «Простой / Расширенный» вверху по центру. В простом режиме — только «Главная» с одной кнопкой и карточкой Telegram. В расширенном открываются вкладки сверху: Главная, Стратегии, Хостлисты, Диагностика, Журнал, Настройки."/>

                            <!-- 3. Вкладки -->
                            <TextBlock Text="3. Что где находится" FontWeight="Bold" Margin="0,14,0,6"
                                       FontFamily="{StaticResource DisplayFont}"/>
                            <StackPanel>
                                <TextBlock Style="{StaticResource Muted}" FontSize="12.5" TextWrapping="Wrap" Text="• Главная — статус, большая кнопка вкл/выкл, выбор цели, переподбор."/>
                                <TextBlock Style="{StaticResource Muted}" FontSize="12.5" TextWrapping="Wrap" Margin="0,3,0,0" Text="• Стратегии — готовые пресеты по группам (Основные, Telegram, Личные/Сгенерированные). Справа — описание, подключённые хостлисты и «терминал» аргументов winws2. Кнопки: Применить, Дублировать (чтобы править копию), Сохранить, Удалить."/>
                                <TextBlock Style="{StaticResource Muted}" FontSize="12.5" TextWrapping="Wrap" Margin="0,3,0,0" Text="• Хостлисты — списки доменов, к которым применяется обход (один домен = одна строка). Список «proxy» — адрес вашего MTProxy для Telegram."/>
                                <TextBlock Style="{StaticResource Muted}" FontSize="12.5" TextWrapping="Wrap" Margin="0,3,0,0" Text="• Диагностика — подбор/генерация стратегии и матрица доступности сервисов (см. ниже)."/>
                                <TextBlock Style="{StaticResource Muted}" FontSize="12.5" TextWrapping="Wrap" Margin="0,3,0,0" Text="• Журнал — живой вывод движка (для диагностики проблем)."/>
                                <TextBlock Style="{StaticResource Muted}" FontSize="12.5" TextWrapping="Wrap" Margin="0,3,0,0" Text="• Настройки — обновление движка, автозапуск, авто-починка, игровой фильтр, обход по IP."/>
                            </StackPanel>

                            <!-- 4. Диагностика -->
                            <TextBlock Text="4. Диагностика, подбор и генерация" FontWeight="Bold" Margin="0,14,0,4"
                                       FontFamily="{StaticResource DisplayFont}"/>
                            <StackPanel>
                                <TextBlock Style="{StaticResource Muted}" FontSize="12.5" TextWrapping="Wrap" Text="• «Подобрать лучшую» — перебирает готовые стратегии и оставляет ту, у которой меньше всего ошибок по выбранной цели."/>
                                <TextBlock Style="{StaticResource Muted}" FontSize="12.5" TextWrapping="Wrap" Margin="0,3,0,0" Text="• «Сгенерировать стратегию» — собирает ПЕРСОНАЛЬНУЮ стратегию: тестирует компоненты и оптимизирует Discord и YouTube по отдельности, затем складывает в одно комбо именно под вашего провайдера."/>
                                <TextBlock Style="{StaticResource Muted}" FontSize="12.5" TextWrapping="Wrap" Margin="0,3,0,0" Text="• «Диагностика» — просто показывает текущую доступность (HTTP / TLS 1.2 / TLS 1.3 / пинг) по сервисам, без подбора. По упавшей ячейке видно, что именно режет провайдер."/>
                                <TextBlock Style="{StaticResource Muted}" FontSize="12.5" TextWrapping="Wrap" Margin="0,3,0,0" Text="• После подбора/генерации список «Успешные стратегии» позволяет сохранить любые рабочие варианты в пресеты (не только лучший)."/>
                                <TextBlock Style="{StaticResource Muted}" FontSize="12.5" TextWrapping="Wrap" Margin="0,3,0,0" Text="• «Свои цели» — добавьте свой сайт: приложение найдёт его поддомены и домены того же бренда в других зонах (yandex.ru → yandex.kz/md…), будет проверять их в диагностике, учитывать при подборе/генерации и применять к ним обход."/>
                            </StackPanel>

                            <!-- 5. Настройки -->
                            <TextBlock Text="5. Полезное в Настройках" FontWeight="Bold" Margin="0,14,0,4"
                                       FontFamily="{StaticResource DisplayFont}"/>
                            <StackPanel>
                                <TextBlock Style="{StaticResource Muted}" FontSize="12.5" TextWrapping="Wrap" Text="• Авто-починка — фоном следит за Discord и YouTube; если обход сломался, сам переподбирает рабочую стратегию."/>
                                <TextBlock Style="{StaticResource Muted}" FontSize="12.5" TextWrapping="Wrap" Margin="0,3,0,0" Text="• Игровой фильтр — по умолчанию ВЫКЛ, обход не трогает игровой трафик. Включайте, только если душат саму игру."/>
                                <TextBlock Style="{StaticResource Muted}" FontSize="12.5" TextWrapping="Wrap" Margin="0,3,0,0" Text="• Обход по IP — если ресурс режут по адресам, а не доменам: соберите подсети Discord/Telegram (резолв доменов), список подключается через токен {IPSET}."/>
                                <TextBlock Style="{StaticResource Muted}" FontSize="12.5" TextWrapping="Wrap" Margin="0,3,0,0" Text="• Движок и приложение обновляются с GitHub; если api недоступен у провайдера — проверка идёт и через обычный github.com."/>
                            </StackPanel>

                            <!-- 6. Telegram через прокси -->
                            <TextBlock Text="6. Telegram через ваш прокси" FontWeight="Bold" Margin="0,14,0,4"
                                       FontFamily="{StaticResource DisplayFont}"/>
                            <TextBlock Style="{StaticResource Muted}" FontSize="12.5" TextWrapping="Wrap"
                                       Text="Пресеты Telegram НЕ чинят сам прокси и не «лечат» приложение напрямую. Они помогают вашему клиенту дозвониться до MTProxy (десинкуют рукопожатие к IP прокси) и заодно чинят веб-версию в браузере (web.telegram.org). Включите пресет, укажите «Хост» прокси по подсказке — и подключайтесь в Telegram именно через ваш прокси. Адрес прокси можно поменять позже в Хостлистах, список «proxy»."/>

                            <!-- 7. Если не работает -->
                            <TextBlock Text="7. Если не работает" FontWeight="Bold" Margin="0,14,0,4"
                                       FontFamily="{StaticResource DisplayFont}"/>
                            <TextBlock Style="{StaticResource Muted}" FontSize="12.5" TextWrapping="Wrap"
                                       Text="Стратегии зависят от оператора связи — одна и та же не работает у всех одинаково. Порядок действий: попробуйте другой пресет из списка → «Подобрать лучшую» → «Сгенерировать стратегию». Для Telegram через прокси пробуйте «вариант 2» и «вариант 3» вручную (автоподбор его не проверяет). Если совсем ничего не пробивает — это, скорее всего, сторона регулятора; для Telegram смените сам прокси."/>

                            <Button Content="Понятно" Command="{Binding CloseHowItWorksCommand}"
                                    Style="{StaticResource StartStopButton}" HorizontalAlignment="Right" Margin="0,18,0,0"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- ============ Modal: add / edit a custom target ============ -->
            <Grid Grid.Row="0" Grid.RowSpan="2" Panel.ZIndex="100" Background="#C0000000"
                  Visibility="{Binding ShowTargetPopup, Converter={StaticResource BoolToVis}}">
                <Border Style="{StaticResource ModalCard}" MaxWidth="500" MaxHeight="660"
                        VerticalAlignment="Center" HorizontalAlignment="Center"
                        BorderBrush="{StaticResource AccentBrush}" BorderThickness="1">
                    <Border.RenderTransform><ScaleTransform/></Border.RenderTransform>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <TextBlock>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource H2}">
                                        <Setter Property="Text" Value="Своя цель"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding TargetIsNew}" Value="True">
                                                <Setter Property="Text" Value="Новая цель"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <Button Content="✕" Command="{Binding CloseTargetPopupCommand}"
                                    Style="{StaticResource GhostButton}" HorizontalAlignment="Right"
                                    VerticalAlignment="Top" Padding="9,2" MinWidth="0"/>
                        </Grid>

                        <TextBlock Grid.Row="1" Style="{StaticResource Muted}" TextWrapping="Wrap" Margin="0,6,0,0"
                                   Text="Укажите корневой домен сайта (например yandex.ru). По кнопке приложение найдёт его поддомены (crt.sh) и домены того же бренда на других зонах, которые реально существуют (yandex.kz, yandex.md…). Проверьте список, добавьте/уберите свои и сохраните."/>

                        <Grid Grid.Row="2" Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Margin="0,0,8,0"
                                     Text="{Binding TargetRootInput, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="1" Command="{Binding ExpandTargetCommand}"
                                    Style="{StaticResource GhostButton}">
                                <TextBlock>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Найти домены"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsExpandingTarget}" Value="True">
                                                    <Setter Property="Text" Value="Ищу…"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Button>
                        </Grid>

                        <TextBlock Grid.Row="3" Text="Домены цели (по одному в строке)"
                                   Style="{StaticResource Muted}" FontSize="11" Margin="0,12,0,6"/>
                        <TextBox Grid.Row="4" MinHeight="160"
                                 Text="{Binding TargetDomainsText, UpdateSourceTrigger=PropertyChanged}"
                                 AcceptsReturn="True" TextWrapping="NoWrap" Background="{StaticResource BgBrush}"
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                 FontFamily="{StaticResource MonoFont}" FontSize="12.5"/>

                        <TextBlock Grid.Row="5" Text="{Binding TargetStatus}" Style="{StaticResource Muted}"
                                   FontSize="11.5" TextWrapping="Wrap" Margin="0,10,0,0"/>

                        <StackPanel Grid.Row="6" Orientation="Horizontal" Margin="0,14,0,0">
                            <Button Content="Сохранить цель" Command="{Binding SaveTargetCommand}"
                                    Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"/>
                            <Button Content="Закрыть" Command="{Binding CloseTargetPopupCommand}"
                                    Style="{StaticResource GhostButton}"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
